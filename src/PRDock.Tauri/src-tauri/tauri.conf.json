{
  "$schema": "https://raw.githubusercontent.com/nicegui-org/nicegui/main/nicegui/static/tauri.v2.schema.json",
  "productName": "PRDock",
  "version": "0.1.0",
  "identifier": "com.prdock.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "PRDock",
        "label": "main",
        "width": 400,
        "height": 900,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": true,
        "transparent": true,
        "url": "index.html"
      },
      {
        "title": "PRDock Badge",
        "label": "badge",
        "width": 260,
        "height": 50,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "transparent": true,
        "visible": false,
        "url": "badge.html",
        "backgroundColor": [0, 0, 0, 0]
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    },
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [],
      "pubkey": ""
    }
  }
}
