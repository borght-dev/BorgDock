{
  "$schema": "https://raw.githubusercontent.com/nicegui-org/nicegui/main/nicegui/static/tauri.v2.schema.json",
  "productName": "PRDock",
  "version": "1.0.12",
  "identifier": "com.prdock.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "PRDock",
        "label": "main",
        "width": 400,
        "height": 900,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": true,
        "transparent": true,
        "skipTaskbar": true,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; connect-src 'self' https://api.github.com https://*.visualstudio.com https://dev.azure.com; img-src 'self' https://avatars.githubusercontent.com data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "createUpdaterArtifacts": "v1Compatible"
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/borght-dev/PRDock/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlFNTA1NjczMDg4QjIwNkMKUldSc0lJc0ljMVpRbmlETnNWMmJHNVVNSWg4b09oUklGVE9TbjZEYytvUEt6VFJpWmVoM0pydmkK",
      "dangerousInsecureTransportProtocol": true
    }
  }
}
