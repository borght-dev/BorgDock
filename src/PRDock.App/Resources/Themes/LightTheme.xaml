<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Background -->
    <Color x:Key="BackgroundColor">#F4F5F7</Color>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />

    <!-- CardBackground -->
    <Color x:Key="CardBackgroundColor">#FFFFFF</Color>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}" />

    <!-- CardBorder -->
    <Color x:Key="CardBorderColor">#0F000000</Color>
    <SolidColorBrush x:Key="CardBorderBrush" Color="{StaticResource CardBorderColor}" />

    <!-- CardBorderMyPR -->
    <Color x:Key="CardBorderMyPRColor">#332563EB</Color>
    <SolidColorBrush x:Key="CardBorderMyPRBrush" Color="{StaticResource CardBorderMyPRColor}" />

    <!-- TextPrimary -->
    <Color x:Key="TextPrimaryColor">#1A1D26</Color>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />

    <!-- TextSecondary -->
    <Color x:Key="TextSecondaryColor">#2E3342</Color>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />

    <!-- TextTertiary -->
    <Color x:Key="TextTertiaryColor">#5A5F72</Color>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource TextTertiaryColor}" />

    <!-- Text hierarchy expansion -->
    <Color x:Key="TextMutedColor">#7A7F92</Color>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}" />
    <Color x:Key="TextFaintColor">#9298AA</Color>
    <SolidColorBrush x:Key="TextFaintBrush" Color="{StaticResource TextFaintColor}" />
    <Color x:Key="TextGhostColor">#B8BCC8</Color>
    <SolidColorBrush x:Key="TextGhostBrush" Color="{StaticResource TextGhostColor}" />

    <!-- Accent -->
    <Color x:Key="AccentColor">#2563EB</Color>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />

    <!-- AccentForeground -->
    <Color x:Key="AccentForegroundColor">#FFFFFF</Color>
    <SolidColorBrush x:Key="AccentForegroundBrush" Color="{StaticResource AccentForegroundColor}" />

    <!-- AccentSubtle -->
    <Color x:Key="AccentSubtleColor">#0F2563EB</Color>
    <SolidColorBrush x:Key="AccentSubtleBrush" Color="{StaticResource AccentSubtleColor}" />

    <!-- Purple accent -->
    <Color x:Key="PurpleColor">#7C3AED</Color>
    <SolidColorBrush x:Key="PurpleBrush" Color="{StaticResource PurpleColor}" />
    <SolidColorBrush x:Key="PurpleSoftBrush" Color="#0F7C3AED" />
    <SolidColorBrush x:Key="PurpleBorderBrush" Color="#247C3AED" />

    <!-- StatusGreen -->
    <Color x:Key="StatusGreenColor">#16A34A</Color>
    <SolidColorBrush x:Key="StatusGreenBrush" Color="{StaticResource StatusGreenColor}" />

    <!-- StatusRed -->
    <Color x:Key="StatusRedColor">#DC2626</Color>
    <SolidColorBrush x:Key="StatusRedBrush" Color="{StaticResource StatusRedColor}" />

    <!-- StatusYellow -->
    <Color x:Key="StatusYellowColor">#D97706</Color>
    <SolidColorBrush x:Key="StatusYellowBrush" Color="{StaticResource StatusYellowColor}" />

    <!-- StatusGray -->
    <Color x:Key="StatusGrayColor">#94A3B8</Color>
    <SolidColorBrush x:Key="StatusGrayBrush" Color="{StaticResource StatusGrayColor}" />

    <!-- Separator -->
    <Color x:Key="SeparatorColor">#12000000</Color>
    <SolidColorBrush x:Key="SeparatorBrush" Color="{StaticResource SeparatorColor}" />

    <!-- FilterChip -->
    <Color x:Key="FilterChipBackgroundColor">#0A000000</Color>
    <SolidColorBrush x:Key="FilterChipBackgroundBrush" Color="{StaticResource FilterChipBackgroundColor}" />
    <Color x:Key="FilterChipForegroundColor">#5A5F72</Color>
    <SolidColorBrush x:Key="FilterChipForegroundBrush" Color="{StaticResource FilterChipForegroundColor}" />

    <!-- Surfaces and chrome -->
    <SolidColorBrush x:Key="SidebarGradientTopBrush" Color="#F4F5F7" />
    <SolidColorBrush x:Key="SidebarGradientBottomBrush" Color="#EEEEF2" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />

    <!-- SurfaceRaised -->
    <Color x:Key="SurfaceRaisedColor">#05000000</Color>
    <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="{StaticResource SurfaceRaisedColor}" />

    <!-- SurfaceHover -->
    <Color x:Key="SurfaceHoverColor">#08000000</Color>
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="{StaticResource SurfaceHoverColor}" />

    <!-- SubtleBorder -->
    <Color x:Key="SubtleBorderColor">#0F000000</Color>
    <SolidColorBrush x:Key="SubtleBorderBrush" Color="{StaticResource SubtleBorderColor}" />

    <!-- StrongBorder -->
    <Color x:Key="StrongBorderColor">#1F000000</Color>
    <SolidColorBrush x:Key="StrongBorderBrush" Color="{StaticResource StrongBorderColor}" />

    <!-- Controls -->
    <Color x:Key="IconButtonBackgroundColor">Transparent</Color>
    <SolidColorBrush x:Key="IconButtonBackgroundBrush" Color="{StaticResource IconButtonBackgroundColor}" />
    <Color x:Key="IconButtonHoverColor">#0A000000</Color>
    <SolidColorBrush x:Key="IconButtonHoverBrush" Color="{StaticResource IconButtonHoverColor}" />
    <Color x:Key="IconButtonPressedColor">#14000000</Color>
    <SolidColorBrush x:Key="IconButtonPressedBrush" Color="{StaticResource IconButtonPressedColor}" />
    <Color x:Key="IconButtonForegroundColor">#5A5F72</Color>
    <SolidColorBrush x:Key="IconButtonForegroundBrush" Color="{StaticResource IconButtonForegroundColor}" />

    <!-- Action buttons -->
    <Color x:Key="ActionSecondaryBackgroundColor">Transparent</Color>
    <SolidColorBrush x:Key="ActionSecondaryBackgroundBrush" Color="{StaticResource ActionSecondaryBackgroundColor}" />
    <Color x:Key="ActionSecondaryForegroundColor">#2563EB</Color>
    <SolidColorBrush x:Key="ActionSecondaryForegroundBrush" Color="{StaticResource ActionSecondaryForegroundColor}" />
    <Color x:Key="ActionSuccessBackgroundColor">#1216A34A</Color>
    <SolidColorBrush x:Key="ActionSuccessBackgroundBrush" Color="{StaticResource ActionSuccessBackgroundColor}" />
    <Color x:Key="ActionSuccessForegroundColor">#16A34A</Color>
    <SolidColorBrush x:Key="ActionSuccessForegroundBrush" Color="{StaticResource ActionSuccessForegroundColor}" />
    <Color x:Key="ActionDangerBackgroundColor">#0FDC2626</Color>
    <SolidColorBrush x:Key="ActionDangerBackgroundBrush" Color="{StaticResource ActionDangerBackgroundColor}" />
    <Color x:Key="ActionDangerForegroundColor">#DC2626</Color>
    <SolidColorBrush x:Key="ActionDangerForegroundBrush" Color="{StaticResource ActionDangerForegroundColor}" />

    <!-- Scrollbar -->
    <Color x:Key="ScrollbarThumbColor">#1A000000</Color>
    <SolidColorBrush x:Key="ScrollbarThumbBrush" Color="{StaticResource ScrollbarThumbColor}" />
    <Color x:Key="ScrollbarThumbHoverColor">#2E000000</Color>
    <SolidColorBrush x:Key="ScrollbarThumbHoverBrush" Color="{StaticResource ScrollbarThumbHoverColor}" />

    <!-- PR Number Badge -->
    <Color x:Key="PrNumberBadgeBackgroundColor">#0A000000</Color>
    <SolidColorBrush x:Key="PrNumberBadgeBackgroundBrush" Color="{StaticResource PrNumberBadgeBackgroundColor}" />
    <Color x:Key="PrNumberBadgeForegroundColor">#5A5F72</Color>
    <SolidColorBrush x:Key="PrNumberBadgeForegroundBrush" Color="{StaticResource PrNumberBadgeForegroundColor}" />
    <Color x:Key="PrNumberMyBadgeBackgroundColor">#0F2563EB</Color>
    <SolidColorBrush x:Key="PrNumberMyBadgeBackgroundBrush" Color="{StaticResource PrNumberMyBadgeBackgroundColor}" />
    <Color x:Key="PrNumberMyBadgeForegroundColor">#2563EB</Color>
    <SolidColorBrush x:Key="PrNumberMyBadgeForegroundBrush" Color="{StaticResource PrNumberMyBadgeForegroundColor}" />

    <!-- Success badge -->
    <Color x:Key="SuccessBadgeBackgroundColor">#1216A34A</Color>
    <SolidColorBrush x:Key="SuccessBadgeBackgroundBrush" Color="{StaticResource SuccessBadgeBackgroundColor}" />
    <Color x:Key="SuccessBadgeForegroundColor">#16A34A</Color>
    <SolidColorBrush x:Key="SuccessBadgeForegroundBrush" Color="{StaticResource SuccessBadgeForegroundColor}" />
    <SolidColorBrush x:Key="SuccessBadgeBorderBrush" Color="#2E16A34A" />

    <!-- Warning badge -->
    <Color x:Key="WarningBadgeBackgroundColor">#0FB45309</Color>
    <SolidColorBrush x:Key="WarningBadgeBackgroundBrush" Color="{StaticResource WarningBadgeBackgroundColor}" />
    <Color x:Key="WarningBadgeForegroundColor">#B45309</Color>
    <SolidColorBrush x:Key="WarningBadgeForegroundBrush" Color="{StaticResource WarningBadgeForegroundColor}" />
    <SolidColorBrush x:Key="WarningBadgeBorderBrush" Color="#24B45309" />

    <!-- Error badge -->
    <Color x:Key="ErrorBadgeBackgroundColor">#0FDC2626</Color>
    <SolidColorBrush x:Key="ErrorBadgeBackgroundBrush" Color="{StaticResource ErrorBadgeBackgroundColor}" />
    <Color x:Key="ErrorBadgeForegroundColor">#DC2626</Color>
    <SolidColorBrush x:Key="ErrorBadgeForegroundBrush" Color="{StaticResource ErrorBadgeForegroundColor}" />
    <SolidColorBrush x:Key="ErrorBadgeBorderBrush" Color="#24DC2626" />

    <!-- Neutral badge -->
    <Color x:Key="NeutralBadgeBackgroundColor">#0F7C3AED</Color>
    <SolidColorBrush x:Key="NeutralBadgeBackgroundBrush" Color="{StaticResource NeutralBadgeBackgroundColor}" />
    <Color x:Key="NeutralBadgeForegroundColor">#7C3AED</Color>
    <SolidColorBrush x:Key="NeutralBadgeForegroundBrush" Color="{StaticResource NeutralBadgeForegroundColor}" />
    <SolidColorBrush x:Key="NeutralBadgeBorderBrush" Color="#247C3AED" />

    <!-- Draft badge -->
    <Color x:Key="DraftBadgeBackgroundColor">#0A000000</Color>
    <SolidColorBrush x:Key="DraftBadgeBackgroundBrush" Color="{StaticResource DraftBadgeBackgroundColor}" />
    <Color x:Key="DraftBadgeForegroundColor">#7A7F92</Color>
    <SolidColorBrush x:Key="DraftBadgeForegroundBrush" Color="{StaticResource DraftBadgeForegroundColor}" />
    <SolidColorBrush x:Key="DraftBadgeBorderBrush" Color="#24000000" />

    <!-- Review status -->
    <SolidColorBrush x:Key="ReviewApprovedBrush" Color="#16A34A" />
    <SolidColorBrush x:Key="ReviewChangesRequestedBrush" Color="#DC2626" />
    <SolidColorBrush x:Key="ReviewRequiredBrush" Color="#B45309" />
    <SolidColorBrush x:Key="ReviewCommentedBrush" Color="#5A5F72" />

    <!-- Comment count -->
    <Color x:Key="CommentCountForegroundColor">#7A7F92</Color>
    <SolidColorBrush x:Key="CommentCountForegroundBrush" Color="{StaticResource CommentCountForegroundColor}" />

    <!-- Branch/target badges -->
    <SolidColorBrush x:Key="BranchBadgeBgBrush" Color="#0F2563EB" />
    <SolidColorBrush x:Key="BranchBadgeBorderBrush" Color="#242563EB" />
    <SolidColorBrush x:Key="TargetBadgeBgBrush" Color="#08000000" />
    <SolidColorBrush x:Key="TargetBadgeBorderBrush" Color="#14000000" />

    <!-- Input field -->
    <SolidColorBrush x:Key="InputBgBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="InputBorderBrush" Color="#1F000000" />

    <!-- Row states -->
    <SolidColorBrush x:Key="SelectedRowBgBrush" Color="#0B2563EB" />
    <SolidColorBrush x:Key="ExpandedRowBgBrush" Color="#03000000" />

    <!-- Status bar -->
    <SolidColorBrush x:Key="StatusBarBgBrush" Color="#E0FFFFFF" />

    <!-- Modal/overlay -->
    <SolidColorBrush x:Key="OverlayBgBrush" Color="#59000000" />
    <SolidColorBrush x:Key="ModalBgBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="ModalBorderBrush" Color="#14000000" />

    <!-- Title bar -->
    <SolidColorBrush x:Key="TitleBarBgBrush" Color="#E0FFFFFF" />

    <!-- Logo gradient -->
    <Color x:Key="LogoGradientStartColor">#2563EB</Color>
    <Color x:Key="LogoGradientEndColor">#7C3AED</Color>

    <!-- Avatar text -->
    <SolidColorBrush x:Key="AvatarTextBrush" Color="#FFFFFFFF" />

    <!-- Check row backgrounds -->
    <SolidColorBrush x:Key="CheckPassedBgBrush" Color="#0816A34A" />
    <SolidColorBrush x:Key="CheckPassedBorderBrush" Color="#1A16A34A" />
    <SolidColorBrush x:Key="CheckFailedBgBrush" Color="#08DC2626" />
    <SolidColorBrush x:Key="CheckFailedBorderBrush" Color="#1ADC2626" />

    <!-- Glow effect colors -->
    <Color x:Key="GreenGlowColor">#1F16A34A</Color>
    <Color x:Key="RedGlowColor">#2DDC2626</Color>

    <!-- Floating badge -->
    <SolidColorBrush x:Key="BadgeGlassBrush" Color="#CCF4F6F9" />
    <SolidColorBrush x:Key="BadgeSurfaceBrush" Color="#E6F0F2F5" />
    <SolidColorBrush x:Key="BadgeBorderBrush" Color="#18000000" />
    <SolidColorBrush x:Key="BadgeGlowGreenBrush" Color="#4016A34A" />
    <SolidColorBrush x:Key="BadgeGlowRedBrush" Color="#40DC2626" />
    <SolidColorBrush x:Key="BadgeGlowYellowBrush" Color="#40B45309" />
    <SolidColorBrush x:Key="BadgeProgressTrackBrush" Color="#12000000" />

    <!-- Diff / Code -->
    <Color x:Key="DiffAddedBgColor">#1216A34A</Color>
    <SolidColorBrush x:Key="DiffAddedBgBrush" Color="{StaticResource DiffAddedBgColor}" />
    <Color x:Key="DiffDeletedBgColor">#0FDC2626</Color>
    <SolidColorBrush x:Key="DiffDeletedBgBrush" Color="{StaticResource DiffDeletedBgColor}" />
    <SolidColorBrush x:Key="DiffHunkHeaderBrush" Color="#08000000" />
    <SolidColorBrush x:Key="TabActiveBrush" Color="#2563EB" />
    <SolidColorBrush x:Key="TabInactiveBrush" Color="#5A5F72" />
    <SolidColorBrush x:Key="CodeBlockBgBrush" Color="#F4F5F7" />
    <SolidColorBrush x:Key="SyntaxKeywordBrush" Color="#A626A4" />
    <SolidColorBrush x:Key="SyntaxStringBrush" Color="#50A14F" />
    <SolidColorBrush x:Key="SyntaxCommentBrush" Color="#A0A1A7" />
    <SolidColorBrush x:Key="SyntaxNumberBrush" Color="#986801" />
    <SolidColorBrush x:Key="SyntaxTypeBrush" Color="#C18401" />
    <SolidColorBrush x:Key="SyntaxPlainBrush" Color="#383A42" />
    <FontFamily x:Key="CodeFontFamily">Cascadia Code, Cascadia Mono, Consolas, Courier New</FontFamily>

    <!-- Wizard-specific -->
    <Color x:Key="WizardStepActiveColor">#2563EB</Color>
    <SolidColorBrush x:Key="WizardStepActiveBrush" Color="{StaticResource WizardStepActiveColor}" />
    <Color x:Key="WizardStepCompleteColor">#16A34A</Color>
    <SolidColorBrush x:Key="WizardStepCompleteBrush" Color="{StaticResource WizardStepCompleteColor}" />
    <Color x:Key="WizardStepInactiveColor">#B8BCC8</Color>
    <SolidColorBrush x:Key="WizardStepInactiveBrush" Color="{StaticResource WizardStepInactiveColor}" />
    <SolidColorBrush x:Key="WizardStepTrackBrush" Color="#14000000" />

</ResourceDictionary>
