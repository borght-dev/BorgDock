<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Background — warm off-white, not sterile -->
    <Color x:Key="BackgroundColor">#F5F5F0</Color>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />

    <!-- CardBackground -->
    <Color x:Key="CardBackgroundColor">#FFFFFF</Color>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}" />

    <!-- CardBorderMyPR -->
    <Color x:Key="CardBorderMyPRColor">#2563EB</Color>
    <SolidColorBrush x:Key="CardBorderMyPRBrush" Color="{StaticResource CardBorderMyPRColor}" />

    <!-- TextPrimary — rich near-black -->
    <Color x:Key="TextPrimaryColor">#111827</Color>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />

    <!-- TextSecondary -->
    <Color x:Key="TextSecondaryColor">#5F6B7A</Color>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />

    <!-- TextTertiary -->
    <Color x:Key="TextTertiaryColor">#94A3B8</Color>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource TextTertiaryColor}" />

    <!-- StatusGreen — deeper, more saturated -->
    <Color x:Key="StatusGreenColor">#059669</Color>
    <SolidColorBrush x:Key="StatusGreenBrush" Color="{StaticResource StatusGreenColor}" />

    <!-- StatusRed -->
    <Color x:Key="StatusRedColor">#DC2626</Color>
    <SolidColorBrush x:Key="StatusRedBrush" Color="{StaticResource StatusRedColor}" />

    <!-- StatusYellow -->
    <Color x:Key="StatusYellowColor">#B45309</Color>
    <SolidColorBrush x:Key="StatusYellowBrush" Color="{StaticResource StatusYellowColor}" />

    <!-- StatusGray -->
    <Color x:Key="StatusGrayColor">#94A3B8</Color>
    <SolidColorBrush x:Key="StatusGrayBrush" Color="{StaticResource StatusGrayColor}" />

    <!-- Accent -->
    <Color x:Key="AccentColor">#2563EB</Color>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentForegroundBrush" Color="White" />
    <SolidColorBrush x:Key="AccentSubtleBrush" Color="#EFF6FF" />

    <!-- FilterChip -->
    <SolidColorBrush x:Key="FilterChipBackgroundBrush" Color="#E8EBF0" />
    <SolidColorBrush x:Key="FilterChipForegroundBrush" Color="#475569" />

    <!-- Surfaces and chrome -->
    <SolidColorBrush x:Key="SidebarGradientTopBrush" Color="#F5F5F0" />
    <SolidColorBrush x:Key="SidebarGradientBottomBrush" Color="#EEEEE8" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FAFAF8" />
    <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="#F0F0EC" />
    <SolidColorBrush x:Key="SubtleBorderBrush" Color="#E2E5EB" />
    <SolidColorBrush x:Key="StrongBorderBrush" Color="#CBD2DC" />

    <!-- Controls -->
    <SolidColorBrush x:Key="IconButtonBackgroundBrush" Color="#F0F0EC" />
    <SolidColorBrush x:Key="IconButtonHoverBrush" Color="#E2E5EB" />
    <SolidColorBrush x:Key="IconButtonPressedBrush" Color="#CBD2DC" />
    <SolidColorBrush x:Key="IconButtonForegroundBrush" Color="#475569" />
    <SolidColorBrush x:Key="ActionSecondaryBackgroundBrush" Color="#F0F0EC" />
    <SolidColorBrush x:Key="ActionSecondaryForegroundBrush" Color="#2563EB" />
    <SolidColorBrush x:Key="ActionDangerBackgroundBrush" Color="#FEF2F2" />
    <SolidColorBrush x:Key="ActionDangerForegroundBrush" Color="#DC2626" />

    <!-- Badges -->
    <SolidColorBrush x:Key="SuccessBadgeBackgroundBrush" Color="#D1FAE5" />
    <SolidColorBrush x:Key="SuccessBadgeForegroundBrush" Color="#065F46" />
    <SolidColorBrush x:Key="WarningBadgeBackgroundBrush" Color="#FEF3C7" />
    <SolidColorBrush x:Key="WarningBadgeForegroundBrush" Color="#92400E" />
    <SolidColorBrush x:Key="ErrorBadgeBackgroundBrush" Color="#FEE2E2" />
    <SolidColorBrush x:Key="ErrorBadgeForegroundBrush" Color="#991B1B" />
    <SolidColorBrush x:Key="NeutralBadgeBackgroundBrush" Color="#EDE9FE" />
    <SolidColorBrush x:Key="NeutralBadgeForegroundBrush" Color="#5B21B6" />

    <!-- Scrollbar -->
    <SolidColorBrush x:Key="ScrollbarThumbBrush" Color="#CBD2DC" />
    <SolidColorBrush x:Key="ScrollbarThumbHoverBrush" Color="#94A3B8" />

    <!-- PR Number Badge -->
    <SolidColorBrush x:Key="PrNumberBadgeBackgroundBrush" Color="#F0F0EC" />
    <SolidColorBrush x:Key="PrNumberBadgeForegroundBrush" Color="#5F6B7A" />
    <SolidColorBrush x:Key="PrNumberMyBadgeBackgroundBrush" Color="#DBEAFE" />
    <SolidColorBrush x:Key="PrNumberMyBadgeForegroundBrush" Color="#1D4ED8" />

    <!-- Draft badge -->
    <SolidColorBrush x:Key="DraftBadgeBackgroundBrush" Color="#E8EBF0" />
    <SolidColorBrush x:Key="DraftBadgeForegroundBrush" Color="#5F6B7A" />

    <!-- Review status -->
    <SolidColorBrush x:Key="ReviewApprovedBrush" Color="#059669" />
    <SolidColorBrush x:Key="ReviewChangesRequestedBrush" Color="#DC2626" />
    <SolidColorBrush x:Key="ReviewRequiredBrush" Color="#B45309" />
    <SolidColorBrush x:Key="ReviewCommentedBrush" Color="#5F6B7A" />

    <!-- Comment count -->
    <SolidColorBrush x:Key="CommentCountForegroundBrush" Color="#5F6B7A" />

    <!-- Separator -->
    <SolidColorBrush x:Key="SeparatorBrush" Color="#E2E5EB" />

    <!-- Diff / Code -->
    <SolidColorBrush x:Key="DiffAddedBgBrush" Color="#D4EDDA" />
    <SolidColorBrush x:Key="DiffDeletedBgBrush" Color="#F8D7DA" />
    <SolidColorBrush x:Key="DiffHunkHeaderBrush" Color="#E2E3F1" />
    <SolidColorBrush x:Key="TabActiveBrush" Color="#2563EB" />
    <SolidColorBrush x:Key="TabInactiveBrush" Color="#5F6B7A" />
    <SolidColorBrush x:Key="CodeBlockBgBrush" Color="#F6F8FA" />
    <FontFamily x:Key="CodeFontFamily">Consolas, Courier New</FontFamily>

    <!-- Wizard-specific -->
    <SolidColorBrush x:Key="WizardStepActiveBrush" Color="#2563EB" />
    <SolidColorBrush x:Key="WizardStepCompleteBrush" Color="#059669" />
    <SolidColorBrush x:Key="WizardStepInactiveBrush" Color="#CBD2DC" />
    <SolidColorBrush x:Key="WizardStepTrackBrush" Color="#E2E5EB" />

</ResourceDictionary>
