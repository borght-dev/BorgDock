<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Background -->
    <Color x:Key="BackgroundColor">#0A0C14</Color>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />

    <!-- CardBackground -->
    <Color x:Key="CardBackgroundColor">#0D0F17</Color>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}" />

    <!-- CardBorder -->
    <Color x:Key="CardBorderColor">#0F8B8FA3</Color>
    <SolidColorBrush x:Key="CardBorderBrush" Color="{StaticResource CardBorderColor}" />

    <!-- CardBorderMyPR -->
    <Color x:Key="CardBorderMyPRColor">#3363B3ED</Color>
    <SolidColorBrush x:Key="CardBorderMyPRBrush" Color="{StaticResource CardBorderMyPRColor}" />

    <!-- TextPrimary -->
    <Color x:Key="TextPrimaryColor">#E2E4EA</Color>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />

    <!-- TextSecondary -->
    <Color x:Key="TextSecondaryColor">#C0C4D4</Color>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />

    <!-- TextTertiary -->
    <Color x:Key="TextTertiaryColor">#8B8FA3</Color>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource TextTertiaryColor}" />

    <!-- Text hierarchy expansion -->
    <Color x:Key="TextMutedColor">#5A5E6A</Color>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}" />
    <Color x:Key="TextFaintColor">#4A4E5A</Color>
    <SolidColorBrush x:Key="TextFaintBrush" Color="{StaticResource TextFaintColor}" />
    <Color x:Key="TextGhostColor">#3A3E4A</Color>
    <SolidColorBrush x:Key="TextGhostBrush" Color="{StaticResource TextGhostColor}" />

    <!-- Accent -->
    <Color x:Key="AccentColor">#63B3ED</Color>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />

    <!-- AccentForeground -->
    <Color x:Key="AccentForegroundColor">#0A0C14</Color>
    <SolidColorBrush x:Key="AccentForegroundBrush" Color="{StaticResource AccentForegroundColor}" />

    <!-- AccentSubtle -->
    <Color x:Key="AccentSubtleColor">#1463B3ED</Color>
    <SolidColorBrush x:Key="AccentSubtleBrush" Color="{StaticResource AccentSubtleColor}" />

    <!-- Purple accent -->
    <Color x:Key="PurpleColor">#A78BFA</Color>
    <SolidColorBrush x:Key="PurpleBrush" Color="{StaticResource PurpleColor}" />
    <SolidColorBrush x:Key="PurpleSoftBrush" Color="#14A78BFA" />
    <SolidColorBrush x:Key="PurpleBorderBrush" Color="#33A78BFA" />

    <!-- StatusGreen -->
    <Color x:Key="StatusGreenColor">#34D399</Color>
    <SolidColorBrush x:Key="StatusGreenBrush" Color="{StaticResource StatusGreenColor}" />

    <!-- StatusRed -->
    <Color x:Key="StatusRedColor">#F87171</Color>
    <SolidColorBrush x:Key="StatusRedBrush" Color="{StaticResource StatusRedColor}" />

    <!-- StatusYellow -->
    <Color x:Key="StatusYellowColor">#F59E0B</Color>
    <SolidColorBrush x:Key="StatusYellowBrush" Color="{StaticResource StatusYellowColor}" />

    <!-- StatusGray -->
    <Color x:Key="StatusGrayColor">#5A5E6A</Color>
    <SolidColorBrush x:Key="StatusGrayBrush" Color="{StaticResource StatusGrayColor}" />

    <!-- Separator -->
    <Color x:Key="SeparatorColor">#0F8B8FA3</Color>
    <SolidColorBrush x:Key="SeparatorBrush" Color="{StaticResource SeparatorColor}" />

    <!-- FilterChip -->
    <Color x:Key="FilterChipBackgroundColor">#0F8B8FA3</Color>
    <SolidColorBrush x:Key="FilterChipBackgroundBrush" Color="{StaticResource FilterChipBackgroundColor}" />
    <Color x:Key="FilterChipForegroundColor">#8B8FA3</Color>
    <SolidColorBrush x:Key="FilterChipForegroundBrush" Color="{StaticResource FilterChipForegroundColor}" />

    <!-- Surfaces and chrome -->
    <SolidColorBrush x:Key="SidebarGradientTopBrush" Color="#0A0C14" />
    <SolidColorBrush x:Key="SidebarGradientBottomBrush" Color="#0D0F17" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#0D0F17" />

    <!-- SurfaceRaised -->
    <Color x:Key="SurfaceRaisedColor">#058B8FA3</Color>
    <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="{StaticResource SurfaceRaisedColor}" />

    <!-- SurfaceHover -->
    <Color x:Key="SurfaceHoverColor">#088B8FA3</Color>
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="{StaticResource SurfaceHoverColor}" />

    <!-- SubtleBorder -->
    <Color x:Key="SubtleBorderColor">#0F8B8FA3</Color>
    <SolidColorBrush x:Key="SubtleBorderBrush" Color="{StaticResource SubtleBorderColor}" />

    <!-- StrongBorder -->
    <Color x:Key="StrongBorderColor">#148B8FA3</Color>
    <SolidColorBrush x:Key="StrongBorderBrush" Color="{StaticResource StrongBorderColor}" />

    <!-- Controls -->
    <Color x:Key="IconButtonBackgroundColor">Transparent</Color>
    <SolidColorBrush x:Key="IconButtonBackgroundBrush" Color="{StaticResource IconButtonBackgroundColor}" />
    <Color x:Key="IconButtonHoverColor">#0F8B8FA3</Color>
    <SolidColorBrush x:Key="IconButtonHoverBrush" Color="{StaticResource IconButtonHoverColor}" />
    <Color x:Key="IconButtonPressedColor">#148B8FA3</Color>
    <SolidColorBrush x:Key="IconButtonPressedBrush" Color="{StaticResource IconButtonPressedColor}" />
    <Color x:Key="IconButtonForegroundColor">#8B8FA3</Color>
    <SolidColorBrush x:Key="IconButtonForegroundBrush" Color="{StaticResource IconButtonForegroundColor}" />

    <!-- Action buttons -->
    <Color x:Key="ActionSecondaryBackgroundColor">Transparent</Color>
    <SolidColorBrush x:Key="ActionSecondaryBackgroundBrush" Color="{StaticResource ActionSecondaryBackgroundColor}" />
    <Color x:Key="ActionSecondaryForegroundColor">#63B3ED</Color>
    <SolidColorBrush x:Key="ActionSecondaryForegroundBrush" Color="{StaticResource ActionSecondaryForegroundColor}" />
    <Color x:Key="ActionSuccessBackgroundColor">#1A34D399</Color>
    <SolidColorBrush x:Key="ActionSuccessBackgroundBrush" Color="{StaticResource ActionSuccessBackgroundColor}" />
    <Color x:Key="ActionSuccessForegroundColor">#34D399</Color>
    <SolidColorBrush x:Key="ActionSuccessForegroundBrush" Color="{StaticResource ActionSuccessForegroundColor}" />
    <Color x:Key="ActionDangerBackgroundColor">#1AF87171</Color>
    <SolidColorBrush x:Key="ActionDangerBackgroundBrush" Color="{StaticResource ActionDangerBackgroundColor}" />
    <Color x:Key="ActionDangerForegroundColor">#F87171</Color>
    <SolidColorBrush x:Key="ActionDangerForegroundBrush" Color="{StaticResource ActionDangerForegroundColor}" />

    <!-- Scrollbar -->
    <Color x:Key="ScrollbarThumbColor">#1F8B8FA3</Color>
    <SolidColorBrush x:Key="ScrollbarThumbBrush" Color="{StaticResource ScrollbarThumbColor}" />
    <Color x:Key="ScrollbarThumbHoverColor">#338B8FA3</Color>
    <SolidColorBrush x:Key="ScrollbarThumbHoverBrush" Color="{StaticResource ScrollbarThumbHoverColor}" />

    <!-- PR Number Badge -->
    <Color x:Key="PrNumberBadgeBackgroundColor">#0F8B8FA3</Color>
    <SolidColorBrush x:Key="PrNumberBadgeBackgroundBrush" Color="{StaticResource PrNumberBadgeBackgroundColor}" />
    <Color x:Key="PrNumberBadgeForegroundColor">#8B8FA3</Color>
    <SolidColorBrush x:Key="PrNumberBadgeForegroundBrush" Color="{StaticResource PrNumberBadgeForegroundColor}" />
    <Color x:Key="PrNumberMyBadgeBackgroundColor">#1463B3ED</Color>
    <SolidColorBrush x:Key="PrNumberMyBadgeBackgroundBrush" Color="{StaticResource PrNumberMyBadgeBackgroundColor}" />
    <Color x:Key="PrNumberMyBadgeForegroundColor">#63B3ED</Color>
    <SolidColorBrush x:Key="PrNumberMyBadgeForegroundBrush" Color="{StaticResource PrNumberMyBadgeForegroundColor}" />

    <!-- Success badge -->
    <Color x:Key="SuccessBadgeBackgroundColor">#1A34D399</Color>
    <SolidColorBrush x:Key="SuccessBadgeBackgroundBrush" Color="{StaticResource SuccessBadgeBackgroundColor}" />
    <Color x:Key="SuccessBadgeForegroundColor">#34D399</Color>
    <SolidColorBrush x:Key="SuccessBadgeForegroundBrush" Color="{StaticResource SuccessBadgeForegroundColor}" />
    <SolidColorBrush x:Key="SuccessBadgeBorderBrush" Color="#4034D399" />

    <!-- Warning badge -->
    <Color x:Key="WarningBadgeBackgroundColor">#1AFBBF24</Color>
    <SolidColorBrush x:Key="WarningBadgeBackgroundBrush" Color="{StaticResource WarningBadgeBackgroundColor}" />
    <Color x:Key="WarningBadgeForegroundColor">#FBBF24</Color>
    <SolidColorBrush x:Key="WarningBadgeForegroundBrush" Color="{StaticResource WarningBadgeForegroundColor}" />
    <SolidColorBrush x:Key="WarningBadgeBorderBrush" Color="#1FFBBF24" />

    <!-- Error badge -->
    <Color x:Key="ErrorBadgeBackgroundColor">#1AF87171</Color>
    <SolidColorBrush x:Key="ErrorBadgeBackgroundBrush" Color="{StaticResource ErrorBadgeBackgroundColor}" />
    <Color x:Key="ErrorBadgeForegroundColor">#F87171</Color>
    <SolidColorBrush x:Key="ErrorBadgeForegroundBrush" Color="{StaticResource ErrorBadgeForegroundColor}" />
    <SolidColorBrush x:Key="ErrorBadgeBorderBrush" Color="#33F87171" />

    <!-- Neutral badge -->
    <Color x:Key="NeutralBadgeBackgroundColor">#14A78BFA</Color>
    <SolidColorBrush x:Key="NeutralBadgeBackgroundBrush" Color="{StaticResource NeutralBadgeBackgroundColor}" />
    <Color x:Key="NeutralBadgeForegroundColor">#A78BFA</Color>
    <SolidColorBrush x:Key="NeutralBadgeForegroundBrush" Color="{StaticResource NeutralBadgeForegroundColor}" />
    <SolidColorBrush x:Key="NeutralBadgeBorderBrush" Color="#33A78BFA" />

    <!-- Draft badge -->
    <Color x:Key="DraftBadgeBackgroundColor">#148B8FA3</Color>
    <SolidColorBrush x:Key="DraftBadgeBackgroundBrush" Color="{StaticResource DraftBadgeBackgroundColor}" />
    <Color x:Key="DraftBadgeForegroundColor">#6B6F80</Color>
    <SolidColorBrush x:Key="DraftBadgeForegroundBrush" Color="{StaticResource DraftBadgeForegroundColor}" />
    <SolidColorBrush x:Key="DraftBadgeBorderBrush" Color="#408B8FA3" />

    <!-- Review status -->
    <SolidColorBrush x:Key="ReviewApprovedBrush" Color="#34D399" />
    <SolidColorBrush x:Key="ReviewChangesRequestedBrush" Color="#F87171" />
    <SolidColorBrush x:Key="ReviewRequiredBrush" Color="#FBBF24" />
    <SolidColorBrush x:Key="ReviewCommentedBrush" Color="#8B8FA3" />

    <!-- Comment count -->
    <Color x:Key="CommentCountForegroundColor">#5A5E6A</Color>
    <SolidColorBrush x:Key="CommentCountForegroundBrush" Color="{StaticResource CommentCountForegroundColor}" />

    <!-- Branch/target badges -->
    <SolidColorBrush x:Key="BranchBadgeBgBrush" Color="#1463B3ED" />
    <SolidColorBrush x:Key="BranchBadgeBorderBrush" Color="#2663B3ED" />
    <SolidColorBrush x:Key="TargetBadgeBgBrush" Color="#0F8B8FA3" />
    <SolidColorBrush x:Key="TargetBadgeBorderBrush" Color="#1A8B8FA3" />

    <!-- Input field -->
    <SolidColorBrush x:Key="InputBgBrush" Color="#0A8B8FA3" />
    <SolidColorBrush x:Key="InputBorderBrush" Color="#148B8FA3" />

    <!-- Row states -->
    <SolidColorBrush x:Key="SelectedRowBgBrush" Color="#0A63B3ED" />
    <SolidColorBrush x:Key="ExpandedRowBgBrush" Color="#058B8FA3" />

    <!-- Status bar -->
    <SolidColorBrush x:Key="StatusBarBgBrush" Color="#990D0F17" />

    <!-- Modal/overlay -->
    <SolidColorBrush x:Key="OverlayBgBrush" Color="#A6000000" />
    <SolidColorBrush x:Key="ModalBgBrush" Color="#FF12141E" />
    <SolidColorBrush x:Key="ModalBorderBrush" Color="#1A8B8FA3" />

    <!-- Title bar -->
    <SolidColorBrush x:Key="TitleBarBgBrush" Color="#CC0D0F17" />

    <!-- Logo gradient -->
    <Color x:Key="LogoGradientStartColor">#63B3ED</Color>
    <Color x:Key="LogoGradientEndColor">#A78BFA</Color>

    <!-- Avatar text -->
    <SolidColorBrush x:Key="AvatarTextBrush" Color="#FF0D0F17" />

    <!-- Check row backgrounds -->
    <SolidColorBrush x:Key="CheckPassedBgBrush" Color="#0534D399" />
    <SolidColorBrush x:Key="CheckPassedBorderBrush" Color="#0F34D399" />
    <SolidColorBrush x:Key="CheckFailedBgBrush" Color="#0AF87171" />
    <SolidColorBrush x:Key="CheckFailedBorderBrush" Color="#1AF87171" />

    <!-- Glow effect colors -->
    <Color x:Key="GreenGlowColor">#4D34D399</Color>
    <Color x:Key="RedGlowColor">#80F87171</Color>

    <!-- Floating badge -->
    <SolidColorBrush x:Key="BadgeGlassBrush" Color="#CC111827" />
    <SolidColorBrush x:Key="BadgeSurfaceBrush" Color="#E6111827" />
    <SolidColorBrush x:Key="BadgeBorderBrush" Color="#25FFFFFF" />
    <SolidColorBrush x:Key="BadgeGlowGreenBrush" Color="#4034D399" />
    <SolidColorBrush x:Key="BadgeGlowRedBrush" Color="#40F87171" />
    <SolidColorBrush x:Key="BadgeGlowYellowBrush" Color="#40FBBF24" />
    <SolidColorBrush x:Key="BadgeProgressTrackBrush" Color="#15FFFFFF" />

    <!-- Diff / Code -->
    <Color x:Key="DiffAddedBgColor">#1A34D399</Color>
    <SolidColorBrush x:Key="DiffAddedBgBrush" Color="{StaticResource DiffAddedBgColor}" />
    <Color x:Key="DiffDeletedBgColor">#1AF87171</Color>
    <SolidColorBrush x:Key="DiffDeletedBgBrush" Color="{StaticResource DiffDeletedBgColor}" />
    <SolidColorBrush x:Key="DiffHunkHeaderBrush" Color="#0F8B8FA3" />
    <SolidColorBrush x:Key="TabActiveBrush" Color="#63B3ED" />
    <SolidColorBrush x:Key="TabInactiveBrush" Color="#8B8FA3" />
    <SolidColorBrush x:Key="CodeBlockBgBrush" Color="#0A0C14" />
    <SolidColorBrush x:Key="SyntaxKeywordBrush" Color="#C678DD" />
    <SolidColorBrush x:Key="SyntaxStringBrush" Color="#98C379" />
    <SolidColorBrush x:Key="SyntaxCommentBrush" Color="#5C6370" />
    <SolidColorBrush x:Key="SyntaxNumberBrush" Color="#D19A66" />
    <SolidColorBrush x:Key="SyntaxTypeBrush" Color="#E5C07B" />
    <SolidColorBrush x:Key="SyntaxPlainBrush" Color="#ABB2BF" />
    <FontFamily x:Key="CodeFontFamily">Cascadia Code, Cascadia Mono, Consolas, Courier New</FontFamily>

    <!-- Wizard-specific -->
    <Color x:Key="WizardStepActiveColor">#63B3ED</Color>
    <SolidColorBrush x:Key="WizardStepActiveBrush" Color="{StaticResource WizardStepActiveColor}" />
    <Color x:Key="WizardStepCompleteColor">#34D399</Color>
    <SolidColorBrush x:Key="WizardStepCompleteBrush" Color="{StaticResource WizardStepCompleteColor}" />
    <Color x:Key="WizardStepInactiveColor">#3A3E4A</Color>
    <SolidColorBrush x:Key="WizardStepInactiveBrush" Color="{StaticResource WizardStepInactiveColor}" />
    <SolidColorBrush x:Key="WizardStepTrackBrush" Color="#148B8FA3" />

</ResourceDictionary>
