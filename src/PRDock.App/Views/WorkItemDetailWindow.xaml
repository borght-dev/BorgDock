<Window x:Class="PRDock.App.Views.WorkItemDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:PRDock.App.Views"
        Title="Work Item Detail"
        WindowStyle="None"
        AllowsTransparency="True"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        Width="600"
        MinWidth="400"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="Segoe UI">

    <views:WorkItemDetailPanel x:Name="DetailPanel" />
</Window>
