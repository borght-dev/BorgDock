<UserControl x:Class="PRDock.App.Views.SettingsFlyout"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PRDock.App.ViewModels"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Margin" Value="0,12,0,6" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="Margin" Value="0,6,0,2" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Settings"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="16,12,16,6" />

        <!-- Scrollable content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="16,0,16,0">
            <StackPanel>

                <!-- ==================== GitHub ==================== -->
                <TextBlock Text="GitHub" Style="{StaticResource SectionHeaderStyle}" />

                <TextBlock Text="Auth method" Style="{StaticResource FieldLabelStyle}" />
                <ComboBox AutomationProperties.AutomationId="AuthMethodComboBox"
                          ItemsSource="{Binding AuthMethodOptions}"
                          SelectedItem="{Binding AuthMethod, Mode=TwoWay}"
                          Margin="0,0,0,4" />

                <TextBlock Text="Username" Style="{StaticResource FieldLabelStyle}" />
                <TextBox AutomationProperties.AutomationId="UsernameTextBox"
                         Text="{Binding Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,4" />

                <TextBlock Text="Personal access token" Style="{StaticResource FieldLabelStyle}" />
                <PasswordBox AutomationProperties.AutomationId="PatPasswordBox"
                             x:Name="PatPasswordBox"
                             Margin="0,0,0,4" />

                <TextBlock Style="{StaticResource FieldLabelStyle}">
                    <Run Text="Poll interval: " />
                    <Run Text="{Binding PollIntervalSeconds, Mode=OneWay}" />
                    <Run Text="s" />
                </TextBlock>
                <Slider AutomationProperties.AutomationId="PollIntervalSlider"
                        Minimum="15" Maximum="300"
                        Value="{Binding PollIntervalSeconds, Mode=TwoWay}"
                        TickFrequency="15"
                        IsSnapToTickEnabled="True"
                        Margin="0,0,0,4" />

                <!-- ==================== Repositories ==================== -->
                <TextBlock Text="Repositories" Style="{StaticResource SectionHeaderStyle}" />

                <StackPanel Orientation="Exampletal" Margin="0,0,0,4">
                    <Button AutomationProperties.AutomationId="AddRepoButton"
                            Content="Add"
                            Command="{Binding AddRepositoryCommand}"
                            Padding="8,2" Margin="0,0,4,0" />
                    <Button AutomationProperties.AutomationId="RemoveRepoButton"
                            Content="Remove"
                            Command="{Binding RemoveRepositoryCommand}"
                            Padding="8,2" />
                </StackPanel>

                <ListBox AutomationProperties.AutomationId="RepoListBox"
                         ItemsSource="{Binding Repositories}"
                         SelectedItem="{Binding SelectedRepository, Mode=TwoWay}"
                         MinHeight="60"
                         MaxHeight="120"
                         Margin="0,0,0,4">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <Run Text="{Binding Owner, Mode=OneWay}" /><Run Text="/" /><Run Text="{Binding Name, Mode=OneWay}" />
                            </TextBlock>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Selected repo detail -->
                <StackPanel Visibility="{Binding SelectedRepository, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Owner" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox AutomationProperties.AutomationId="RepoOwnerTextBox"
                             Text="{Binding SelectedRepository.Owner, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,4" />

                    <TextBlock Text="Name" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox AutomationProperties.AutomationId="RepoNameTextBox"
                             Text="{Binding SelectedRepository.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,4" />

                    <TextBlock Text="Worktree base path" Style="{StaticResource FieldLabelStyle}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox AutomationProperties.AutomationId="WorktreeBasePathTextBox"
                                 Text="{Binding SelectedRepository.WorktreeBasePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Grid.Column="0" />
                        <Button AutomationProperties.AutomationId="BrowseWorktreeButton"
                                Content="..."
                                Click="BrowseWorktreePath_Click"
                                Grid.Column="1"
                                Width="28" Margin="4,0,0,0" />
                    </Grid>

                    <TextBlock Text="Worktree subfolder" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox AutomationProperties.AutomationId="WorktreeSubfolderTextBox"
                             Text="{Binding SelectedRepository.WorktreeSubfolder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,4" />

                    <TextBlock Text="Fix prompt template" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox AutomationProperties.AutomationId="FixPromptTemplateTextBox"
                             Text="{Binding SelectedRepository.FixPromptTemplate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             MinHeight="48"
                             Margin="0,0,0,4" />
                </StackPanel>

                <!-- ==================== Appearance ==================== -->
                <TextBlock Text="Appearance" Style="{StaticResource SectionHeaderStyle}" />

                <TextBlock Text="Sidebar edge" Style="{StaticResource FieldLabelStyle}" />
                <ComboBox AutomationProperties.AutomationId="SidebarEdgeComboBox"
                          ItemsSource="{Binding SidebarEdgeOptions}"
                          SelectedItem="{Binding SidebarEdge, Mode=TwoWay}"
                          Margin="0,0,0,4" />

                <TextBlock Text="Mode" Style="{StaticResource FieldLabelStyle}" />
                <ComboBox AutomationProperties.AutomationId="SidebarModeComboBox"
                          ItemsSource="{Binding SidebarModeOptions}"
                          SelectedItem="{Binding SidebarMode, Mode=TwoWay}"
                          Margin="0,0,0,4" />

                <TextBlock Style="{StaticResource FieldLabelStyle}">
                    <Run Text="Width: " />
                    <Run Text="{Binding SidebarWidthPx, Mode=OneWay}" />
                    <Run Text="px" />
                </TextBlock>
                <Slider AutomationProperties.AutomationId="SidebarWidthSlider"
                        Minimum="200" Maximum="800"
                        Value="{Binding SidebarWidthPx, Mode=TwoWay}"
                        TickFrequency="10"
                        IsSnapToTickEnabled="True"
                        Margin="0,0,0,4" />

                <TextBlock Text="Theme" Style="{StaticResource FieldLabelStyle}" />
                <ComboBox AutomationProperties.AutomationId="ThemeComboBox"
                          ItemsSource="{Binding ThemeOptions}"
                          SelectedItem="{Binding Theme, Mode=TwoWay}"
                          Margin="0,0,0,4" />

                <TextBlock Text="Editor command" Style="{StaticResource FieldLabelStyle}" />
                <TextBox AutomationProperties.AutomationId="EditorCommandTextBox"
                         Text="{Binding EditorCommand, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,4" />

                <!-- ==================== Notifications ==================== -->
                <TextBlock Text="Notifications" Style="{StaticResource SectionHeaderStyle}" />

                <CheckBox AutomationProperties.AutomationId="ToastOnCheckStatusChangeCheckBox"
                          Content="Check status changes"
                          IsChecked="{Binding ToastOnCheckStatusChange, Mode=TwoWay}"
                          Margin="0,4,0,2" />
                <CheckBox AutomationProperties.AutomationId="ToastOnNewPRCheckBox"
                          Content="New pull requests"
                          IsChecked="{Binding ToastOnNewPR, Mode=TwoWay}"
                          Margin="0,2,0,2" />
                <CheckBox AutomationProperties.AutomationId="ToastOnReviewUpdateCheckBox"
                          Content="Review updates"
                          IsChecked="{Binding ToastOnReviewUpdate, Mode=TwoWay}"
                          Margin="0,2,0,4" />

                <!-- ==================== Claude Code ==================== -->
                <TextBlock Text="Claude Code" Style="{StaticResource SectionHeaderStyle}" />

                <TextBlock Text="Post-fix action" Style="{StaticResource FieldLabelStyle}" />
                <ComboBox AutomationProperties.AutomationId="PostFixActionComboBox"
                          ItemsSource="{Binding PostFixActionOptions}"
                          SelectedItem="{Binding DefaultPostFixAction, Mode=TwoWay}"
                          Margin="0,0,0,4" />

                <TextBlock Text="Claude Code path override" Style="{StaticResource FieldLabelStyle}" />
                <TextBox AutomationProperties.AutomationId="ClaudeCodePathTextBox"
                         Text="{Binding ClaudeCodePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12" />

            </StackPanel>
        </ScrollViewer>

        <!-- Validation error + Save/Cancel -->
        <StackPanel Grid.Row="2" Margin="16,8,16,12">
            <TextBlock Text="{Binding ValidationError}"
                       Foreground="{DynamicResource StatusRedBrush}"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Margin="0,0,0,6"
                       Visibility="{Binding HasValidationError, Converter={StaticResource BoolToVis}}" />

            <StackPanel Orientation="Exampletal" ExampletalAlignment="Right">
                <Button AutomationProperties.AutomationId="CancelButton"
                        Content="Cancel"
                        Command="{Binding CancelCommand}"
                        Padding="16,6"
                        Margin="0,0,8,0" />
                <Button AutomationProperties.AutomationId="SaveButton"
                        Content="Save"
                        Command="{Binding SaveCommand}"
                        Padding="16,6" />
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
