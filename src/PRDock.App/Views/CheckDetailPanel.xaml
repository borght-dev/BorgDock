<UserControl x:Class="PRDock.App.Views.CheckDetailPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PRDock.App.ViewModels">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <!-- Loading overlay -->
        <Border Background="{DynamicResource BackgroundBrush}"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                Panel.ZIndex="1">
            <TextBlock Text="Loading check details..."
                       ExampletalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="13"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       AutomationProperties.AutomationId="CheckDetailLoadingText" />
        </Border>

        <DockPanel>
            <!-- Header -->
            <Border DockPanel.Dock="Top"
                    Padding="12,8"
                    Background="{DynamicResource CardBackgroundBrush}">
                <StackPanel>
                    <TextBlock Text="{Binding CheckName}"
                               FontWeight="SemiBold"
                               FontSize="14"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               AutomationProperties.AutomationId="CheckDetailName" />
                    <TextBlock Text="{Binding Duration}"
                               FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,2,0,0"
                               AutomationProperties.AutomationId="CheckDetailDuration" />
                </StackPanel>
            </Border>

            <!-- Bottom toolbar -->
            <Border DockPanel.Dock="Bottom"
                    Padding="12,6"
                    Background="{DynamicResource CardBackgroundBrush}">
                <StackPanel Orientation="Exampletal" ExampletalAlignment="Right">
                    <Button Command="{Binding ToggleRawLogCommand}"
                            FontSize="11"
                            Padding="8,4"
                            Margin="0,0,6,0"
                            AutomationProperties.AutomationId="CheckDetailToggleRawLog">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Content" Value="Show full log" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRawLogVisible}" Value="True">
                                        <Setter Property="Content" Value="Hide full log" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="Fix with Claude"
                            Command="{Binding FixWithClaudeCommand}"
                            FontSize="11"
                            Padding="8,4"
                            AutomationProperties.AutomationId="CheckDetailFixWithClaude" />
                </StackPanel>
            </Border>

            <!-- Main content area -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Padding="12,8">
                <StackPanel>
                    <!-- Parsed errors list -->
                    <ItemsControl ItemsSource="{Binding ParsedErrors}"
                                  AutomationProperties.AutomationId="CheckDetailErrorList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,6"
                                        Margin="0,0,0,4"
                                        CornerRadius="4"
                                        Cursor="Hand"
                                        AutomationProperties.AutomationId="CheckDetailErrorItem">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#11EF4444" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsIntroducedByPr}" Value="True">
                                                    <Setter Property="Background" Value="#33EF4444" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.InputBindings>
                                        <MouseBinding Gesture="LeftClick"
                                                      Command="{Binding DataContext.OpenFileInEditorCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                      CommandParameter="{Binding}" />
                                    </Border.InputBindings>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!-- File icon -->
                                        <TextBlock Grid.Column="0" Grid.RowSpan="2"
                                                   Text="&#x1F4C4;"
                                                   FontSize="14"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0" />

                                        <!-- File path + line -->
                                        <TextBlock Grid.Column="1" Grid.Row="0"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextPrimaryBrush}">
                                            <Run Text="{Binding FilePath, Mode=OneWay}" />
                                            <Run Text=":" /><Run Text="{Binding LineNumber, Mode=OneWay}" />
                                        </TextBlock>

                                        <!-- Error message -->
                                        <TextBlock Grid.Column="1" Grid.Row="1"
                                                   Text="{Binding Message}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,2,0,0" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- No errors message -->
                    <TextBlock Text="No parsed errors found."
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,8,0,0"
                               AutomationProperties.AutomationId="CheckDetailNoErrors">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ParsedErrors.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Raw log section -->
                    <Border Margin="0,12,0,0"
                            Visibility="{Binding IsRawLogVisible, Converter={StaticResource BoolToVis}}">
                        <Border Background="{DynamicResource BackgroundBrush}"
                                CornerRadius="4"
                                Padding="8">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          MaxHeight="400"
                                          AutomationProperties.AutomationId="CheckDetailRawLogScroller">
                                <TextBlock Text="{Binding RawLogContent}"
                                           FontFamily="Consolas, Courier New, monospace"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           AutomationProperties.AutomationId="CheckDetailRawLogText" />
                            </ScrollViewer>
                        </Border>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</UserControl>
