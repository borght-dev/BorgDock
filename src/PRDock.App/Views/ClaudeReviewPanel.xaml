<UserControl x:Class="PRDock.App.Views.ClaudeReviewPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AutomationProperties.AutomationId="ClaudeReviewPanel">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      AutomationProperties.AutomationId="ClaudeReviewScrollViewer">
            <StackPanel Margin="8">

                <!-- Summary header -->
                <Border Background="{DynamicResource CardBackgroundBrush}"
                        CornerRadius="6"
                        Padding="12"
                        Margin="0,0,0,8"
                        AutomationProperties.AutomationId="ClaudeReviewSummary">
                    <TextBlock Text="{Binding SummaryText}"
                               FontWeight="SemiBold"
                               FontSize="14"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               AutomationProperties.AutomationId="ClaudeReviewSummaryText" />
                </Border>

                <!-- Critical comments -->
                <ItemsControl ItemsSource="{Binding CriticalComments}"
                              AutomationProperties.AutomationId="CriticalCommentsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#33EF4444"
                                    BorderBrush="#EF4444"
                                    BorderThickness="0,0,0,2"
                                    CornerRadius="6"
                                    Padding="12"
                                    Margin="0,0,0,6"
                                    AutomationProperties.AutomationId="CriticalCommentCard">
                                <StackPanel>
                                    <StackPanel Orientation="Exampletal" Margin="0,0,0,4">
                                        <TextBlock Text="&#x1F534;"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,6,0" />
                                        <TextBlock Text="Critical"
                                                   FontWeight="Bold"
                                                   FontSize="12"
                                                   Foreground="#EF4444"
                                                   VerticalAlignment="Center"
                                                   AutomationProperties.AutomationId="CriticalSeverityLabel" />
                                        <TextBlock Text="{Binding FilePath}"
                                                   FontSize="11"
                                                   FontFamily="{DynamicResource CodeFontFamily}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center"
                                                   AutomationProperties.AutomationId="CommentFilePath" />
                                        <TextBlock FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Margin="4,0,0,0"
                                                   VerticalAlignment="Center"
                                                   AutomationProperties.AutomationId="CommentLineNumber">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding LineNumber}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                            <Run Text=":" /><Run Text="{Binding LineNumber, Mode=OneWay}" />
                                        </TextBlock>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Body}"
                                               TextWrapping="Wrap"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               AutomationProperties.AutomationId="CommentBody" />
                                    <TextBlock FontSize="10"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Margin="0,4,0,0"
                                               AutomationProperties.AutomationId="CommentAuthor">
                                        <Run Text="{Binding Author, Mode=OneWay}" />
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Suggestion comments -->
                <ItemsControl ItemsSource="{Binding SuggestionComments}"
                              AutomationProperties.AutomationId="SuggestionCommentsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#33F59E0B"
                                    BorderBrush="#F59E0B"
                                    BorderThickness="0,0,0,2"
                                    CornerRadius="6"
                                    Padding="12"
                                    Margin="0,0,0,6"
                                    AutomationProperties.AutomationId="SuggestionCommentCard">
                                <StackPanel>
                                    <StackPanel Orientation="Exampletal" Margin="0,0,0,4">
                                        <TextBlock Text="&#x1F7E1;"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,6,0" />
                                        <TextBlock Text="Suggestion"
                                                   FontWeight="Bold"
                                                   FontSize="12"
                                                   Foreground="#F59E0B"
                                                   VerticalAlignment="Center"
                                                   AutomationProperties.AutomationId="SuggestionSeverityLabel" />
                                        <TextBlock Text="{Binding FilePath}"
                                                   FontSize="11"
                                                   FontFamily="{DynamicResource CodeFontFamily}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center" />
                                        <TextBlock FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Margin="4,0,0,0"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding LineNumber}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                            <Run Text=":" /><Run Text="{Binding LineNumber, Mode=OneWay}" />
                                        </TextBlock>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Body}"
                                               TextWrapping="Wrap"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock FontSize="10"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Margin="0,4,0,0">
                                        <Run Text="{Binding Author, Mode=OneWay}" />
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Praise comments -->
                <ItemsControl ItemsSource="{Binding PraiseComments}"
                              AutomationProperties.AutomationId="PraiseCommentsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#3322C55E"
                                    BorderBrush="#22C55E"
                                    BorderThickness="0,0,0,2"
                                    CornerRadius="6"
                                    Padding="12"
                                    Margin="0,0,0,6"
                                    AutomationProperties.AutomationId="PraiseCommentCard">
                                <StackPanel>
                                    <StackPanel Orientation="Exampletal" Margin="0,0,0,4">
                                        <TextBlock Text="&#x1F7E2;"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,6,0" />
                                        <TextBlock Text="Praise"
                                                   FontWeight="Bold"
                                                   FontSize="12"
                                                   Foreground="#22C55E"
                                                   VerticalAlignment="Center"
                                                   AutomationProperties.AutomationId="PraiseSeverityLabel" />
                                        <TextBlock Text="{Binding FilePath}"
                                                   FontSize="11"
                                                   FontFamily="{DynamicResource CodeFontFamily}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding Body}"
                                               TextWrapping="Wrap"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock FontSize="10"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Margin="0,4,0,0">
                                        <Run Text="{Binding Author, Mode=OneWay}" />
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Other/Unknown comments -->
                <ItemsControl ItemsSource="{Binding OtherComments}"
                              AutomationProperties.AutomationId="OtherCommentsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource CardBackgroundBrush}"
                                    BorderBrush="{DynamicResource TextSecondaryBrush}"
                                    BorderThickness="0,0,0,1"
                                    CornerRadius="6"
                                    Padding="12"
                                    Margin="0,0,0,6"
                                    AutomationProperties.AutomationId="OtherCommentCard">
                                <StackPanel>
                                    <StackPanel Orientation="Exampletal" Margin="0,0,0,4">
                                        <TextBlock Text="Comment"
                                                   FontWeight="Bold"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"
                                                   AutomationProperties.AutomationId="OtherSeverityLabel" />
                                        <TextBlock Text="{Binding FilePath}"
                                                   FontSize="11"
                                                   FontFamily="{DynamicResource CodeFontFamily}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding Body}"
                                               TextWrapping="Wrap"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                    <TextBlock FontSize="10"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Margin="0,4,0,0">
                                        <Run Text="{Binding Author, Mode=OneWay}" />
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
