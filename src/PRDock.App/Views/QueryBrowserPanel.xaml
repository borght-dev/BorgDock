<UserControl x:Class="PRDock.App.Views.QueryBrowserPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PRDock.App.ViewModels"
             Background="{DynamicResource CardBackgroundBrush}"
             FontFamily="Segoe UI"
             TextOptions.TextFormattingMode="Display">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Style for query tree items -->
        <Style x:Key="QueryItemStyle" TargetType="Border">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="10,7" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="14,12"
                BorderBrush="{DynamicResource SeparatorBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <TextBlock Text="Saved Queries"
                           FontSize="14" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" />
                <Button ExampletalAlignment="Right"
                        Width="28" Height="28"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand"
                        Command="{Binding ToggleQueryBrowserCommand}"
                        ToolTip="Close">
                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                               Foreground="{DynamicResource TextMutedBrush}" />
                </Button>
            </Grid>
        </Border>

        <!-- Favorites section -->
        <Border Grid.Row="1" Padding="14,8"
                BorderBrush="{DynamicResource SeparatorBrush}"
                BorderThickness="0,0,0,1">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding FavoriteQueries.Count}" Value="0">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel>
                <TextBlock Text="FAVORITES" FontSize="10" FontWeight="Bold"
                           Foreground="{DynamicResource TextGhostBrush}"
                           Margin="0,0,0,6"
                           FontFamily="{DynamicResource CodeFontFamily}" />
                <ItemsControl ItemsSource="{Binding FavoriteQueries}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource QueryItemStyle}"
                                    MouseLeftButtonUp="FavoriteQuery_Click">
                                <Grid>
                                    <StackPanel Orientation="Exampletal">
                                        <TextBlock Text="&#xE735;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="11" Foreground="{DynamicResource AccentBrush}"
                                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="12.5"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Query tree -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                      ExampletalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,4">
                <!-- Loading indicator -->
                <TextBlock Text="Loading queries..."
                           FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                           Margin="14,8"
                           Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />

                <ItemsControl ItemsSource="{Binding QueryTree}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <!-- Folder / Query item -->
                                <Border Style="{StaticResource QueryItemStyle}"
                                        MouseLeftButtonUp="QueryNode_Click">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Orientation="Exampletal" Grid.Column="0">
                                            <!-- Folder/query icon -->
                                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,8,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="&#xE8A5;" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                                                <Setter Property="Text" Value="&#xE8B7;" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="12.5"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>

                                        <!-- Star toggle (non-folders only) -->
                                        <Button Grid.Column="1"
                                                Width="24" Height="24"
                                                Background="Transparent" BorderThickness="0"
                                                Cursor="Hand"
                                                Click="ToggleFavorite_Click"
                                                ToolTip="Toggle favorite">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="11">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="&#xE734;" />
                                                        <Setter Property="Foreground" Value="{DynamicResource TextGhostBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                                <Setter Property="Text" Value="&#xE735;" />
                                                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Button>
                                    </Grid>
                                </Border>

                                <!-- Children (if folder is expanded) -->
                                <ItemsControl ItemsSource="{Binding Children}"
                                              Margin="20,0,0,0"
                                              Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource QueryItemStyle}"
                                                    MouseLeftButtonUp="QueryNode_Click">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Orientation="Exampletal" Grid.Column="0">
                                                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                                   VerticalAlignment="Center" Margin="0,0,8,0">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="&#xE8A5;" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                                                            <Setter Property="Text" Value="&#xE8B7;" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontSize="12.5"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                   VerticalAlignment="Center" />
                                                    </StackPanel>

                                                    <Button Grid.Column="1"
                                                            Width="24" Height="24"
                                                            Background="Transparent" BorderThickness="0"
                                                            Cursor="Hand"
                                                            Click="ToggleFavorite_Click"
                                                            ToolTip="Toggle favorite">
                                                        <Button.Style>
                                                            <Style TargetType="Button">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="11">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="&#xE734;" />
                                                                    <Setter Property="Foreground" Value="{DynamicResource TextGhostBrush}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                                            <Setter Property="Text" Value="&#xE735;" />
                                                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
