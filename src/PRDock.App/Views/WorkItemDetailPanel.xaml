<UserControl x:Class="PRDock.App.Views.WorkItemDetailPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PRDock.App.Converters"
             Background="{DynamicResource CardBackgroundBrush}"
             FontFamily="Segoe UI"
             TextOptions.TextFormattingMode="Display">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:WorkItemStateToColorConverter x:Key="StateToColor" />

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="Margin" Value="0,10,0,4" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="FieldInputStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="BorderBrush" Value="{DynamicResource SubtleBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
            <Setter Property="Padding" Value="16,7" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder"
                                CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ExampletalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="BtnBorder" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource StatusRedBrush}" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="16,12"
                BorderBrush="{DynamicResource SeparatorBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Exampletal" VerticalAlignment="Center">
                    <!-- Type badge -->
                    <Border CornerRadius="4" Padding="8,3" Margin="0,0,8,0"
                            Background="{DynamicResource SurfaceRaisedBrush}">
                        <TextBlock Text="{Binding Type}" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}" />
                    </Border>

                    <TextBlock FontFamily="{DynamicResource CodeFontFamily}"
                               FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNewItem}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                        <Run Text="#" /><Run Text="{Binding Id, Mode=OneWay}" />
                    </TextBlock>

                    <TextBlock Text="New Work Item" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"
                               Visibility="{Binding IsNewItem, Converter={StaticResource BoolToVis}}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Exampletal">
                    <!-- Open in browser -->
                    <Button Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding OpenInBrowserCommand}"
                            Padding="8,5" Margin="0,0,6,0"
                            ToolTip="Open in browser">
                        <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="12" />
                    </Button>

                    <!-- Close -->
                    <Button Width="28" Height="28"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand"
                            Click="Close_Click">
                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   Foreground="{DynamicResource TextMutedBrush}" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Form fields (scrollable) -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      ExampletalScrollBarVisibility="Disabled"
                      Padding="16,0">
            <StackPanel Margin="0,4,0,16">
                <!-- Loading -->
                <TextBlock Text="Loading..."
                           FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                           Margin="0,12"
                           Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />

                <!-- Work item type (new items only) -->
                <StackPanel Visibility="{Binding IsNewItem, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="TYPE" Style="{StaticResource FieldLabelStyle}" />
                    <ComboBox ItemsSource="{Binding WorkItemTypeOptions}"
                              SelectedItem="{Binding NewItemType}"
                              FontSize="12.5" Padding="10,7" />
                </StackPanel>

                <!-- Title -->
                <TextBlock Text="TITLE" Style="{StaticResource FieldLabelStyle}" />
                <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FieldInputStyle}" />

                <!-- State (read-only for existing) -->
                <TextBlock Text="STATE" Style="{StaticResource FieldLabelStyle}" />
                <Border CornerRadius="4" Padding="10,7"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource SubtleBorderBrush}"
                        BorderThickness="1">
                    <StackPanel Orientation="Exampletal">
                        <Ellipse Width="8" Height="8"
                                 Fill="{Binding State, Converter={StaticResource StateToColor}}"
                                 Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding State}" FontSize="12.5"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                    </StackPanel>
                </Border>

                <!-- Assigned To -->
                <TextBlock Text="ASSIGNED TO" Style="{StaticResource FieldLabelStyle}" />
                <TextBox Text="{Binding AssignedTo, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FieldInputStyle}" />

                <!-- Priority -->
                <TextBlock Text="PRIORITY" Style="{StaticResource FieldLabelStyle}" />
                <ComboBox SelectedValue="{Binding Priority}"
                          FontSize="12.5" Padding="10,7">
                    <ComboBoxItem Content="1 - Critical" Tag="1" />
                    <ComboBoxItem Content="2 - High" Tag="2" />
                    <ComboBoxItem Content="3 - Medium" Tag="3" />
                    <ComboBoxItem Content="4 - Low" Tag="4" />
                </ComboBox>

                <!-- Description -->
                <TextBlock Text="DESCRIPTION" Style="{StaticResource FieldLabelStyle}" />
                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FieldInputStyle}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="80"
                         MaxHeight="200"
                         VerticalScrollBarVisibility="Auto" />

                <!-- Tags -->
                <TextBlock Text="TAGS" Style="{StaticResource FieldLabelStyle}" />
                <TextBox Text="{Binding Tags, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FieldInputStyle}" />

                <!-- Area Path (read-only) -->
                <TextBlock Text="AREA PATH" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,10,0,4">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsNewItem}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{Binding AreaPath}" FontSize="12.5"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,0,0,4">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsNewItem}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Iteration Path (read-only) -->
                <TextBlock Text="ITERATION PATH" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,4">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsNewItem}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{Binding IterationPath}" FontSize="12.5"
                           Foreground="{DynamicResource TextSecondaryBrush}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsNewItem}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Attachments -->
                <TextBlock Text="ATTACHMENTS" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,14,0,6">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Attachments.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <ItemsControl ItemsSource="{Binding Attachments}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,5" Margin="0,2"
                                    Background="{DynamicResource SurfaceRaisedBrush}"
                                    CornerRadius="4" Cursor="Hand"
                                    MouseLeftButtonUp="Attachment_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Exampletal" Grid.Column="0">
                                        <TextBlock Text="&#xE723;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                                                   VerticalAlignment="Center" Margin="0,0,6,0" />
                                        <TextBlock Text="{Binding Name}" FontSize="12"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding SizeDisplay}"
                                               FontSize="10.5"
                                               FontFamily="{DynamicResource CodeFontFamily}"
                                               Foreground="{DynamicResource TextGhostBrush}"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer: action buttons + status -->
        <Border Grid.Row="2" Padding="16,10"
                BorderBrush="{DynamicResource SeparatorBrush}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Delete (existing items only) -->
                <Button Grid.Column="0"
                        Command="{Binding DeleteCommand}"
                        Content="Delete" Padding="12,7">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource DangerButtonStyle}">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsNewItem}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Status text -->
                <TextBlock Grid.Column="1" Text="{Binding StatusText}"
                           FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                           VerticalAlignment="Center" Margin="12,0"
                           TextTrimming="CharacterEllipsis" />

                <!-- Save button -->
                <Button Grid.Column="2"
                        Command="{Binding SaveCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                            <Setter Property="Content" Value="Save" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsNewItem}" Value="True">
                                    <Setter Property="Content" Value="Create" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
