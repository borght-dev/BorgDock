<Window x:Class="PRDock.App.Views.PRDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PRDock.App.ViewModels"
        xmlns:conv="clr-namespace:PRDock.App.Converters"
        xmlns:infra="clr-namespace:PRDock.App.Infrastructure"
        Title="PR Detail"
        WindowStyle="None"
        AllowsTransparency="True"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Width="750"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:StatusToColorConverter x:Key="StatusToColorConverter" />

        <!-- Tab button style -->
        <Style x:Key="TabButtonStyle" TargetType="RadioButton">
            <Setter Property="Margin" Value="0,0,2,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="TabBorder"
                                Background="Transparent"
                                Padding="12,8"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent">
                            <ContentPresenter ExampletalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource TabActiveBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Action button base -->
        <Style x:Key="DetailActionButton" TargetType="Button">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ExampletalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Icon button -->
        <Style x:Key="DetailIconButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource IconButtonBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource IconButtonForegroundBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="6"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter ExampletalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource IconButtonHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Thin scrollbar (same as sidebar) -->
        <Style x:Key="DetailScrollThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border CornerRadius="3"
                                Background="{DynamicResource ScrollbarThumbBrush}"
                                Margin="1,2" Opacity="0.6" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DetailScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="6" />
            <Setter Property="MinWidth" Value="6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource DetailScrollThumb}" />
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{DynamicResource StrongBorderBrush}" BorderThickness="1" CornerRadius="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Header -->
                <RowDefinition Height="Auto" /> <!-- Tab bar -->
                <RowDefinition Height="*" />    <!-- Tab content -->
                <RowDefinition Height="Auto" /> <!-- Toast -->
            </Grid.RowDefinitions>

            <!-- ===== HEADER ===== -->
            <Grid Grid.Row="0" Margin="20,16,20,12" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Row 1: PR number + Title + Close button -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" CornerRadius="5" Padding="6,2" Margin="0,2,10,0"
                            VerticalAlignment="Top"
                            Background="{DynamicResource PrNumberBadgeBackgroundBrush}">
                        <TextBlock Text="{Binding Number, StringFormat='#{0}'}"
                                   FontSize="12" FontWeight="Bold"
                                   Foreground="{DynamicResource PrNumberBadgeForegroundBrush}" />
                    </Border>

                    <TextBlock Grid.Column="1"
                               Text="{Binding Title}"
                               FontSize="16" FontWeight="Bold"
                               TextWrapping="Wrap" LineHeight="22"
                               Foreground="{DynamicResource TextPrimaryBrush}" />

                    <Button Grid.Column="2"
                            Content="&#xE711;"
                            FontFamily="Segoe MDL2 Assets" FontSize="12"
                            Command="{Binding CloseCommand}"
                            Style="{StaticResource DetailIconButton}"
                            ToolTip="Close (Esc)" />
                </Grid>

                <!-- Row 2: Author + age + status dot -->
                <StackPanel Grid.Row="1" Orientation="Exampletal" Margin="0,6,0,0">
                    <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}">
                        <Run Text="{Binding AuthorLogin, Mode=OneWay}" />
                        <Run Text=" opened " />
                        <Run Text="{Binding Age, Mode=OneWay}" />
                    </TextBlock>
                    <Ellipse Width="8" Height="8" Margin="8,0,0,0" VerticalAlignment="Center"
                             Fill="{Binding StatusDotColor, Converter={StaticResource StatusToColorConverter}}" />
                </StackPanel>

                <!-- Row 3: Branch refs + copy buttons -->
                <StackPanel Grid.Row="2" Orientation="Exampletal" Margin="0,6,0,0">
                    <TextBlock FontSize="11" FontFamily="{DynamicResource CodeFontFamily}"
                               Foreground="{DynamicResource TextSecondaryBrush}">
                        <Run Text="{Binding HeadRef, Mode=OneWay}" FontWeight="SemiBold" />
                        <Run Text=" &#x2192; " />
                        <Run Text="{Binding BaseRef, Mode=OneWay}" />
                    </TextBlock>
                    <Button Content="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                            Command="{Binding CopyBranchNameCommand}"
                            Style="{StaticResource DetailIconButton}" ToolTip="Copy branch name"
                            Width="24" Height="24" Margin="6,0,0,0" />
                    <Button Content="&#xE71B;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                            Command="{Binding CopyPrUrlCommand}"
                            Style="{StaticResource DetailIconButton}" ToolTip="Copy PR URL"
                            Width="24" Height="24" Margin="2,0,0,0" />
                    <Button Content="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                            Command="{Binding OpenInBrowserCommand}"
                            Style="{StaticResource DetailIconButton}" ToolTip="Open in browser"
                            Width="24" Height="24" Margin="2,0,0,0" />
                    <Button Content="&#xE8AB;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                            Command="{Binding CheckoutBranchCommand}"
                            Style="{StaticResource DetailIconButton}" ToolTip="Checkout branch"
                            Width="24" Height="24" Margin="2,0,0,0" />
                </StackPanel>

                <!-- Row 4: Badges -->
                <StackPanel Grid.Row="3" Orientation="Exampletal" Margin="0,8,0,0">
                    <Border Background="{DynamicResource DraftBadgeBackgroundBrush}"
                            CornerRadius="5" Padding="8,3" Margin="0,0,6,0"
                            Visibility="{Binding IsDraft, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Draft" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource DraftBadgeForegroundBrush}" />
                    </Border>
                    <Border Background="{DynamicResource WarningBadgeBackgroundBrush}"
                            CornerRadius="5" Padding="8,3" Margin="0,0,6,0"
                            Visibility="{Binding HasMergeConflict, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Merge conflict" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource WarningBadgeForegroundBrush}" />
                    </Border>
                    <Border CornerRadius="5" Padding="8,3" Margin="0,0,6,0"
                            Background="{DynamicResource FilterChipBackgroundBrush}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ReviewStatusText}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding ReviewStatusText}" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                    </Border>
                </StackPanel>
            </Grid>

            <!-- ===== TAB BAR ===== -->
            <Border Grid.Row="1" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource SeparatorBrush}">
                <StackPanel Orientation="Exampletal" Margin="16,0">
                    <RadioButton GroupName="DetailTab" IsChecked="True"
                                 Command="{Binding SetTabCommand}" CommandParameter="Description"
                                 Style="{StaticResource TabButtonStyle}">
                        <TextBlock FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}">
                            <Run Text="Description" />
                        </TextBlock>
                    </RadioButton>
                    <RadioButton GroupName="DetailTab"
                                 Command="{Binding SetTabCommand}" CommandParameter="Commits"
                                 Style="{StaticResource TabButtonStyle}">
                        <TextBlock FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}">
                            <Run Text="Commits" />
                            <Run Text="{Binding CommitCount, Mode=OneWay, StringFormat=' ({0})'}"
                                 Foreground="{DynamicResource TextTertiaryBrush}" />
                        </TextBlock>
                    </RadioButton>
                    <RadioButton GroupName="DetailTab"
                                 Command="{Binding SetTabCommand}" CommandParameter="Files"
                                 Style="{StaticResource TabButtonStyle}">
                        <TextBlock FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}">
                            <Run Text="Files" />
                            <Run Text="{Binding FilesChangedCount, Mode=OneWay, StringFormat=' ({0})'}"
                                 Foreground="{DynamicResource TextTertiaryBrush}" />
                        </TextBlock>
                    </RadioButton>
                    <RadioButton GroupName="DetailTab"
                                 Command="{Binding SetTabCommand}" CommandParameter="Checks"
                                 Style="{StaticResource TabButtonStyle}">
                        <TextBlock FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}">
                            <Run Text="Checks" />
                            <Run Text="{Binding CheckRuns.Count, Mode=OneWay, StringFormat=' ({0})'}"
                                 Foreground="{DynamicResource TextTertiaryBrush}" />
                        </TextBlock>
                    </RadioButton>
                    <RadioButton GroupName="DetailTab"
                                 Command="{Binding SetTabCommand}" CommandParameter="Comments"
                                 Style="{StaticResource TabButtonStyle}">
                        <TextBlock FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}">
                            <Run Text="Comments" />
                            <Run Text="{Binding AllComments.Count, Mode=OneWay, StringFormat=' ({0})'}"
                                 Foreground="{DynamicResource TextTertiaryBrush}" />
                        </TextBlock>
                    </RadioButton>
                </StackPanel>
            </Border>

            <!-- ===== TAB CONTENT ===== -->
            <Grid Grid.Row="2">
                <!-- DESCRIPTION TAB -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="20,12,14,12">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource DetailScrollBar}" />
                    </ScrollViewer.Resources>
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveTab}" Value="Description">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <StackPanel>
                        <!-- Empty placeholder -->
                        <TextBlock Text="No description provided."
                                   FontSize="13" FontStyle="Italic"
                                   Foreground="{DynamicResource TextTertiaryBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Body}" Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <!-- Rendered markdown body -->
                        <RichTextBox IsReadOnly="True" BorderThickness="0"
                                     Background="Transparent"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     FontSize="13"
                                     infra:MarkdownTextBlock.Markdown="{Binding Body}">
                            <RichTextBox.Style>
                                <Style TargetType="RichTextBox">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Body}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </RichTextBox.Style>
                        </RichTextBox>
                    </StackPanel>
                </ScrollViewer>

                <!-- COMMITS TAB -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="20,12,14,12">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource DetailScrollBar}" />
                    </ScrollViewer.Resources>
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveTab}" Value="Commits">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <StackPanel>
                        <TextBlock Text="Loading commits..."
                                   FontSize="11" FontStyle="Italic"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   Visibility="{Binding IsCommitsLoading, Converter={StaticResource BoolToVis}}" />
                        <TextBlock Text="{Binding CommitsError}" FontSize="11"
                                   Foreground="{DynamicResource StatusRedBrush}" TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CommitsError}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <ItemsControl ItemsSource="{Binding Commits}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,6" Margin="0,0,0,4" CornerRadius="6"
                                            Background="{DynamicResource SurfaceRaisedBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding ShortSha}"
                                                       FontSize="11"
                                                       FontFamily="{DynamicResource CodeFontFamily}"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       VerticalAlignment="Top"
                                                       Margin="0,0,10,0" />
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding FirstLineMessage}"
                                                           FontSize="12" TextWrapping="Wrap"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxHeight="40" />
                                                <TextBlock FontSize="10" Margin="0,2,0,0"
                                                           Foreground="{DynamicResource TextTertiaryBrush}">
                                                    <Run Text="{Binding AuthorLogin, Mode=OneWay}" />
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <!-- FILES TAB -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="20,12,14,12">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource DetailScrollBar}" />
                    </ScrollViewer.Resources>
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveTab}" Value="Files">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <StackPanel>
                        <TextBlock Text="Loading files..."
                                   FontSize="11" FontStyle="Italic"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   Visibility="{Binding IsFilesLoading, Converter={StaticResource BoolToVis}}" />
                        <TextBlock Text="{Binding FilesError}" FontSize="11"
                                   Foreground="{DynamicResource StatusRedBrush}" TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FilesError}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <!-- Summary bar -->
                        <Border Padding="8,6" Margin="0,0,0,8" CornerRadius="6"
                                Background="{DynamicResource SurfaceBrush}">
                            <TextBlock FontSize="12">
                                <Run Text="{Binding FilesChangedCount, Mode=OneWay}" FontWeight="SemiBold"
                                     Foreground="{DynamicResource TextPrimaryBrush}" />
                                <Run Text=" files changed  " Foreground="{DynamicResource TextSecondaryBrush}" />
                                <Run Text="{Binding TotalAdditions, Mode=OneWay, StringFormat='+{0}'}"
                                     Foreground="{DynamicResource StatusGreenBrush}" FontWeight="SemiBold" />
                                <Run Text="  " />
                                <Run Text="{Binding TotalDeletions, Mode=OneWay, StringFormat='-{0}'}"
                                     Foreground="{DynamicResource StatusRedBrush}" FontWeight="SemiBold" />
                            </TextBlock>
                        </Border>
                        <!-- File list -->
                        <ItemsControl ItemsSource="{Binding FileChanges}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Expander Margin="0,0,0,2">
                                        <Expander.Header>
                                            <Grid Width="680">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" FontSize="11" FontWeight="Bold"
                                                           Margin="0,0,8,0" VerticalAlignment="Center"
                                                           Width="16" TextAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="~" />
                                                            <Setter Property="Foreground" Value="{DynamicResource StatusYellowBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="added">
                                                                    <Setter Property="Text" Value="+" />
                                                                    <Setter Property="Foreground" Value="{DynamicResource StatusGreenBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="removed">
                                                                    <Setter Property="Text" Value="-" />
                                                                    <Setter Property="Foreground" Value="{DynamicResource StatusRedBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="renamed">
                                                                    <Setter Property="Text" Value="R" />
                                                                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Grid.Column="1" Text="{Binding Filename}"
                                                           FontSize="12" VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                                <TextBlock Grid.Column="2" FontSize="11"
                                                           VerticalAlignment="Center" Margin="8,0,0,0">
                                                    <Run Text="{Binding Additions, Mode=OneWay, StringFormat='+{0}'}"
                                                         Foreground="{DynamicResource StatusGreenBrush}" />
                                                    <Run Text=" " />
                                                    <Run Text="{Binding Deletions, Mode=OneWay, StringFormat='-{0}'}"
                                                         Foreground="{DynamicResource StatusRedBrush}" />
                                                </TextBlock>
                                            </Grid>
                                        </Expander.Header>
                                        <Expander.Content>
                                            <!-- Diff view -->
                                            <Border Background="{DynamicResource CodeBlockBgBrush}"
                                                    CornerRadius="4" Padding="8,6" Margin="0,4,0,4">
                                                <TextBlock Text="{Binding Patch}"
                                                           FontFamily="{DynamicResource CodeFontFamily}"
                                                           FontSize="11"
                                                           TextWrapping="Wrap"
                                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                            </Border>
                                        </Expander.Content>
                                    </Expander>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <!-- CHECKS TAB -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="20,12,14,12">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource DetailScrollBar}" />
                    </ScrollViewer.Resources>
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveTab}" Value="Checks">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <StackPanel>
                        <TextBlock Text="Loading checks..."
                                   FontSize="11" FontStyle="Italic"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   Visibility="{Binding IsChecksLoading, Converter={StaticResource BoolToVis}}" />
                        <ItemsControl ItemsSource="{Binding CheckRuns}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,6" Margin="0,0,0,4" CornerRadius="6"
                                            Background="{DynamicResource SurfaceRaisedBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <!-- Status icon -->
                                            <TextBlock Grid.Column="0" FontSize="12" Margin="0,0,8,0"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="&#x23F3;" />
                                                        <Setter Property="Foreground" Value="{DynamicResource StatusYellowBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                                                                <Setter Property="Text" Value="&#x2713;" />
                                                                <Setter Property="Foreground" Value="{DynamicResource StatusGreenBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsFailed}" Value="True">
                                                                <Setter Property="Text" Value="&#x2717;" />
                                                                <Setter Property="Foreground" Value="{DynamicResource StatusRedBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                       FontSize="12" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <!-- Empty state -->
                        <TextBlock FontSize="12" FontStyle="Italic"
                                   Foreground="{DynamicResource TextTertiaryBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="No checks." />
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CheckRuns.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsChecksLoading}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>

                <!-- COMMENTS TAB -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveTab}" Value="Comments">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Comment list -->
                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Margin="20,12,14,4">
                        <ScrollViewer.Resources>
                            <Style TargetType="ScrollBar" BasedOn="{StaticResource DetailScrollBar}" />
                        </ScrollViewer.Resources>
                        <StackPanel>
                            <TextBlock Text="Loading comments..."
                                       FontSize="11" FontStyle="Italic"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       Visibility="{Binding IsCommentsLoading, Converter={StaticResource BoolToVis}}" />
                            <ItemsControl ItemsSource="{Binding AllComments}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="10,8" Margin="0,0,0,6" CornerRadius="6"
                                                Background="{DynamicResource SurfaceRaisedBrush}">
                                            <StackPanel>
                                                <StackPanel Orientation="Exampletal">
                                                    <TextBlock Text="{Binding Author}" FontSize="12"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                                    <TextBlock FontSize="10" Margin="8,0,0,0"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource TextTertiaryBrush}"
                                                               Text="{Binding CreatedAt, StringFormat='{}{0:MMM d, yyyy HH:mm}'}" />
                                                    <!-- Severity badge for Claude comments -->
                                                    <TextBlock FontSize="9" FontWeight="Bold" Margin="8,0,0,0"
                                                               VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Severity}" Value="Critical">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <Setter Property="Text" Value="CRITICAL" />
                                                                        <Setter Property="Foreground" Value="#EF4444" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Severity}" Value="Suggestion">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <Setter Property="Text" Value="SUGGESTION" />
                                                                        <Setter Property="Foreground" Value="#F59E0B" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Severity}" Value="Praise">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <Setter Property="Text" Value="PRAISE" />
                                                                        <Setter Property="Foreground" Value="#22C55E" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                                <!-- File reference for review comments -->
                                                <TextBlock FontSize="10" Margin="0,2,0,0"
                                                           FontFamily="{DynamicResource CodeFontFamily}"
                                                           Foreground="{DynamicResource TextTertiaryBrush}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding FilePath}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                    <Run Text="{Binding FilePath, Mode=OneWay}" />
                                                    <Run Text=":" /><Run Text="{Binding LineNumber, Mode=OneWay}" />
                                                </TextBlock>
                                                <!-- Comment body (markdown) -->
                                                <RichTextBox IsReadOnly="True" BorderThickness="0"
                                                             Background="Transparent"
                                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                                             FontSize="12" Margin="0,4,0,0"
                                                             Padding="0"
                                                             infra:MarkdownTextBlock.Markdown="{Binding Body}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Comment input + review actions -->
                    <Border Grid.Row="1" Padding="20,8,20,12"
                            BorderThickness="0,1,0,0" BorderBrush="{DynamicResource SeparatorBrush}">
                        <StackPanel>
                            <!-- Comment input -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding NewCommentText, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="12" Padding="8,6"
                                         Background="{DynamicResource SurfaceBrush}"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         BorderBrush="{DynamicResource SubtleBorderBrush}"
                                         BorderThickness="1"
                                         AcceptsReturn="True" MaxHeight="80"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto" />
                                <Button Grid.Column="1" Content="Comment"
                                        Command="{Binding PostCommentCommand}"
                                        Background="{DynamicResource AccentBrush}"
                                        Foreground="{DynamicResource AccentForegroundBrush}"
                                        Style="{StaticResource DetailActionButton}"
                                        Margin="6,0,0,0" VerticalAlignment="Bottom" />
                            </Grid>
                            <!-- Review actions -->
                            <StackPanel Orientation="Exampletal">
                                <Button Content="&#x2713; Approve"
                                        Command="{Binding SubmitReviewCommand}"
                                        CommandParameter="APPROVE"
                                        Background="{DynamicResource SuccessBadgeBackgroundBrush}"
                                        Foreground="{DynamicResource SuccessBadgeForegroundBrush}"
                                        Style="{StaticResource DetailActionButton}" />
                                <Button Content="&#x2717; Request Changes"
                                        Command="{Binding SubmitReviewCommand}"
                                        CommandParameter="REQUEST_CHANGES"
                                        Background="{DynamicResource ErrorBadgeBackgroundBrush}"
                                        Foreground="{DynamicResource ErrorBadgeForegroundBrush}"
                                        Style="{StaticResource DetailActionButton}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- ===== TOAST ===== -->
            <Border Grid.Row="3" ExampletalAlignment="Center" Margin="0,0,0,8"
                    CornerRadius="6" Padding="12,6"
                    Background="{DynamicResource SurfaceRaisedBrush}"
                    BorderBrush="{DynamicResource SubtleBorderBrush}"
                    BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ToastMessage}" Value="">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding ToastMessage}" FontSize="11"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
            </Border>
        </Grid>
    </Border>
</Window>
