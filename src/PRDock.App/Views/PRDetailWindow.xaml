<Window x:Class="PRDock.App.Views.PRDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PRDock.App.ViewModels"
        xmlns:conv="clr-namespace:PRDock.App.Converters"
        xmlns:infra="clr-namespace:PRDock.App.Infrastructure"
        Title="PR Detail"
        WindowStyle="None"
        AllowsTransparency="True"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        Width="800"
        MinWidth="600"
        MaxWidth="1200"
        Background="Transparent"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:StatusToColorConverter x:Key="StatusToColorConverter" />
        <conv:ScoreToArcGeometryConverter x:Key="ScoreToArc" />
        <conv:MergeScoreToColorConverter x:Key="MergeScoreToColor" />
        <conv:LabelToVariantConverter x:Key="LabelToVariant" />

        <!-- Tab button style -->
        <Style x:Key="TabButtonStyle" TargetType="RadioButton">
            <Setter Property="Margin" Value="0,0,2,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="TabBorder"
                                Background="Transparent"
                                Padding="14,10"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent">
                            <ContentPresenter ExampletalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource TabActiveBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Outlined action button -->
        <Style x:Key="OutlinedButton" TargetType="Button">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ExampletalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Icon button -->
        <Style x:Key="DetailIconButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextTertiaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource SubtleBorderBrush}" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter ExampletalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Detail action button (for review actions) -->
        <Style x:Key="DetailActionButton" TargetType="Button">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ExampletalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Thin scrollbar -->
        <Style x:Key="DetailScrollThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border CornerRadius="3"
                                Background="{DynamicResource ScrollbarThumbBrush}"
                                Margin="1,2" Opacity="0.6" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DetailScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="6" />
            <Setter Property="MinWidth" Value="6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource DetailScrollThumb}" />
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{DynamicResource StrongBorderBrush}" BorderThickness="1" CornerRadius="12"
            Background="{DynamicResource BackgroundBrush}">
        <Border.Clip>
            <RectangleGeometry RadiusX="12" RadiusY="12">
                <RectangleGeometry.Rect>
                    <MultiBinding Converter="{x:Static conv:SizeToRectConverter.Instance}">
                        <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Border}" />
                        <Binding Path="ActualHeight" RelativeSource="{RelativeSource AncestorType=Border}" />
                    </MultiBinding>
                </RectangleGeometry.Rect>
            </RectangleGeometry>
        </Border.Clip>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Header -->
                <RowDefinition Height="Auto" /> <!-- Tab bar -->
                <RowDefinition Height="*" />    <!-- Tab content -->
                <RowDefinition Height="Auto" /> <!-- Toast -->
            </Grid.RowDefinitions>

            <!-- ===== HEADER ===== -->
            <Grid Grid.Row="0" Margin="24,20,24,16" Background="Transparent"
                  MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Row 0: Status dot + PR number + Draft badge + Close button -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Exampletal" VerticalAlignment="Center">
                        <Ellipse Width="10" Height="10" VerticalAlignment="Center"
                                 Fill="{Binding StatusDotColor, Converter={StaticResource StatusToColorConverter}}" />
                        <TextBlock Margin="8,0,0,0" FontSize="13" FontWeight="Medium"
                                   FontFamily="{DynamicResource CodeFontFamily}"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Text="{Binding Number, StringFormat='#{0}'}"
                                   VerticalAlignment="Center" />
                        <Border Background="{DynamicResource DraftBadgeBackgroundBrush}"
                                CornerRadius="4" Padding="8,2" Margin="10,0,0,0"
                                Visibility="{Binding IsDraft, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="draft" FontSize="11" FontWeight="Medium"
                                       FontFamily="{DynamicResource CodeFontFamily}"
                                       Foreground="{DynamicResource DraftBadgeForegroundBrush}" />
                        </Border>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="&#xE711;"
                            FontFamily="Segoe MDL2 Assets" FontSize="12"
                            Command="{Binding CloseCommand}"
                            Style="{StaticResource DetailIconButton}"
                            ToolTip="Close (Esc)" />
                </Grid>

                <!-- Row 1: Title -->
                <TextBlock Grid.Row="1" Margin="0,8,0,0"
                           Text="{Binding Title}"
                           FontSize="18" FontWeight="Bold"
                           TextWrapping="Wrap" LineHeight="25"
                           Foreground="{DynamicResource TextPrimaryBrush}" />

                <!-- Row 2: Branch pills -->
                <StackPanel Grid.Row="2" Orientation="Exampletal" Margin="0,12,0,0">
                    <Border Background="{DynamicResource BranchBadgeBgBrush}"
                            BorderBrush="{DynamicResource BranchBadgeBorderBrush}"
                            BorderThickness="1" CornerRadius="4" Padding="8,3">
                        <TextBlock Text="{Binding HeadRef}" FontSize="12"
                                   FontFamily="{DynamicResource CodeFontFamily}"
                                   Foreground="{DynamicResource AccentBrush}" />
                    </Border>
                    <TextBlock Text=" &#x2192; " FontSize="12" Margin="8,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextGhostBrush}" />
                    <Border Background="{DynamicResource TargetBadgeBgBrush}"
                            BorderBrush="{DynamicResource TargetBadgeBorderBrush}"
                            BorderThickness="1" CornerRadius="4" Padding="8,3">
                        <TextBlock Text="{Binding BaseRef}" FontSize="12"
                                   FontFamily="{DynamicResource CodeFontFamily}"
                                   Foreground="{DynamicResource TextTertiaryBrush}" />
                    </Border>
                </StackPanel>

                <!-- Row 3: Stats row -->
                <StackPanel Grid.Row="3" Orientation="Exampletal" Margin="0,12,0,0">
                    <TextBlock FontSize="11" Foreground="{DynamicResource TextFaintBrush}"
                               VerticalAlignment="Center" Text="Files" Margin="0,0,5,0" />
                    <TextBlock FontSize="12" FontWeight="SemiBold"
                               FontFamily="{DynamicResource CodeFontFamily}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="{Binding FilesChangedCount}" Margin="0,0,16,0" />

                    <TextBlock FontSize="11" Foreground="{DynamicResource TextFaintBrush}"
                               VerticalAlignment="Center" Text="Commits" Margin="0,0,5,0" />
                    <TextBlock FontSize="12" FontWeight="SemiBold"
                               FontFamily="{DynamicResource CodeFontFamily}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="{Binding CommitCount}" Margin="0,0,16,0" />

                    <TextBlock FontSize="11" Foreground="{DynamicResource TextFaintBrush}"
                               VerticalAlignment="Center" Text="Added" Margin="0,0,5,0" />
                    <TextBlock FontSize="12" FontWeight="SemiBold"
                               FontFamily="{DynamicResource CodeFontFamily}"
                               Foreground="{DynamicResource StatusGreenBrush}"
                               Text="{Binding TotalAdditions, StringFormat='+{0}'}" Margin="0,0,16,0" />

                    <TextBlock FontSize="11" Foreground="{DynamicResource TextFaintBrush}"
                               VerticalAlignment="Center" Text="Removed" Margin="0,0,5,0" />
                    <TextBlock FontSize="12" FontWeight="SemiBold"
                               FontFamily="{DynamicResource CodeFontFamily}"
                               Foreground="{DynamicResource StatusRedBrush}"
                               Text="{Binding TotalDeletions, StringFormat='-{0}'}" />
                </StackPanel>

                <!-- Row 4: Action buttons -->
                <StackPanel Grid.Row="4" Orientation="Exampletal" Margin="0,14,0,0">
                    <Button Command="{Binding RerunChecksCommand}"
                            Background="Transparent"
                            BorderBrush="{DynamicResource AccentBrush}"
                            Style="{StaticResource OutlinedButton}">
                        <TextBlock FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentBrush}">
                            <Run Text="&#x21BB; " /><Run Text="Re-run Checks" />
                        </TextBlock>
                    </Button>
                    <Button Command="{Binding FixWithClaudeCommand}"
                            Background="{DynamicResource PurpleSoftBrush}"
                            BorderBrush="{DynamicResource PurpleBorderBrush}"
                            Style="{StaticResource OutlinedButton}">
                        <TextBlock FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PurpleBrush}">
                            <Run Text="&#x2726; " /><Run Text="Fix with Claude" />
                        </TextBlock>
                    </Button>
                    <Button Command="{Binding OpenInBrowserCommand}"
                            Background="Transparent"
                            BorderBrush="{DynamicResource SubtleBorderBrush}"
                            Style="{StaticResource OutlinedButton}">
                        <TextBlock FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}">
                            <Run Text="&#x2197; " /><Run Text="Open in GitHub" />
                        </TextBlock>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ===== TAB BAR ===== -->
            <Border Grid.Row="1" BorderThickness="0,1,0,1" BorderBrush="{DynamicResource SeparatorBrush}">
                <StackPanel Orientation="Exampletal" Margin="24,0">
                    <RadioButton GroupName="DetailTab" IsChecked="True"
                                 Command="{Binding SetTabCommand}" CommandParameter="Overview"
                                 Style="{StaticResource TabButtonStyle}">
                        <TextBlock FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Text="Overview" />
                    </RadioButton>
                    <RadioButton GroupName="DetailTab"
                                 Command="{Binding SetTabCommand}" CommandParameter="Checks"
                                 Style="{StaticResource TabButtonStyle}">
                        <TextBlock FontSize="12" Foreground="{DynamicResource TextMutedBrush}">
                            <Run Text="Checks " />
                            <Run Text="{Binding PassedChecks, Mode=OneWay, StringFormat='({0}'}" />
                            <Run Text="{Binding TotalChecks, Mode=OneWay, StringFormat='/{0})'}" />
                        </TextBlock>
                    </RadioButton>
                    <RadioButton GroupName="DetailTab"
                                 Command="{Binding SetTabCommand}" CommandParameter="Reviews"
                                 Style="{StaticResource TabButtonStyle}">
                        <TextBlock FontSize="12" Foreground="{DynamicResource TextMutedBrush}">
                            <Run Text="Reviews" />
                            <Run Text="{Binding AllComments.Count, Mode=OneWay, StringFormat=' ({0})'}" />
                        </TextBlock>
                    </RadioButton>
                </StackPanel>
            </Border>

            <!-- ===== TAB CONTENT ===== -->
            <Grid Grid.Row="2">

                <!-- OVERVIEW TAB -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="24,18,18,24">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource DetailScrollBar}" />
                    </ScrollViewer.Resources>
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveTab}" Value="Overview">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <StackPanel>

                        <!-- MERGE READINESS section card -->
                        <Border Padding="14,14,16,14" Margin="0,0,0,16" CornerRadius="8"
                                Background="{DynamicResource SurfaceRaisedBrush}"
                                BorderBrush="{DynamicResource SubtleBorderBrush}"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="MERGE READINESS" FontSize="11" FontWeight="Bold"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="0,0,0,12">
                                    <TextBlock.TextDecorations>
                                        <TextDecorationCollection />
                                    </TextBlock.TextDecorations>
                                </TextBlock>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Merge score ring -->
                                    <Grid Grid.Column="0" Width="48" Height="48" Margin="0,0,16,0"
                                          VerticalAlignment="Center">
                                        <!-- Canvas for absolute-coordinate ring rendering -->
                                        <Canvas Width="38" Height="38"
                                                ExampletalAlignment="Center" VerticalAlignment="Center">
                                            <Ellipse Canvas.Left="5" Canvas.Top="5"
                                                     Width="28" Height="28"
                                                     Stroke="{DynamicResource SubtleBorderBrush}"
                                                     StrokeThickness="3" Fill="Transparent" />
                                            <Path Data="{Binding MergeScore, Converter={StaticResource ScoreToArc}}"
                                                  Stroke="{Binding MergeScore, Converter={StaticResource MergeScoreToColor}}"
                                                  StrokeThickness="3"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round" />
                                        </Canvas>
                                        <TextBlock Text="{Binding MergeScore}"
                                                   ExampletalAlignment="Center" VerticalAlignment="Center"
                                                   FontSize="12" FontWeight="Bold"
                                                   FontFamily="{DynamicResource CodeFontFamily}"
                                                   Foreground="{Binding MergeScore, Converter={StaticResource MergeScoreToColor}}" />
                                    </Grid>

                                    <!-- Readiness checklist -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <!-- CI Checks -->
                                        <StackPanel Orientation="Exampletal" Margin="0,0,0,6">
                                            <TextBlock Width="16" TextAlignment="Center" FontSize="13"
                                                       VerticalAlignment="Center" Margin="0,0,8,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="&#x2717;" />
                                                        <Setter Property="Foreground" Value="{DynamicResource StatusRedBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsChecksPassing}" Value="True">
                                                                <Setter Property="Text" Value="&#x2713;" />
                                                                <Setter Property="Foreground" Value="{DynamicResource StatusGreenBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="CI Checks" FontSize="12" FontWeight="Medium"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <TextBlock Text="{Binding ChecksReadinessDetail}" FontSize="11"
                                                       FontFamily="{DynamicResource CodeFontFamily}"
                                                       Foreground="{DynamicResource TextFaintBrush}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>

                                        <!-- Approvals -->
                                        <StackPanel Orientation="Exampletal" Margin="0,0,0,6">
                                            <TextBlock Width="16" TextAlignment="Center" FontSize="13"
                                                       VerticalAlignment="Center" Margin="0,0,8,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="&#x2717;" />
                                                        <Setter Property="Foreground" Value="{DynamicResource StatusRedBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasApproval}" Value="True">
                                                                <Setter Property="Text" Value="&#x2713;" />
                                                                <Setter Property="Foreground" Value="{DynamicResource StatusGreenBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="Approvals" FontSize="12" FontWeight="Medium"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <TextBlock Text="{Binding ApprovalsReadinessDetail}" FontSize="11"
                                                       FontFamily="{DynamicResource CodeFontFamily}"
                                                       Foreground="{DynamicResource TextFaintBrush}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>

                                        <!-- No Conflicts -->
                                        <StackPanel Orientation="Exampletal" Margin="0,0,0,6">
                                            <TextBlock Width="16" TextAlignment="Center" FontSize="13"
                                                       VerticalAlignment="Center" Margin="0,0,8,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="&#x2717;" />
                                                        <Setter Property="Foreground" Value="{DynamicResource StatusRedBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsConflictFree}" Value="True">
                                                                <Setter Property="Text" Value="&#x2713;" />
                                                                <Setter Property="Foreground" Value="{DynamicResource StatusGreenBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="No Conflicts" FontSize="12" FontWeight="Medium"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <TextBlock Text="{Binding ConflictsReadinessDetail}" FontSize="11"
                                                       FontFamily="{DynamicResource CodeFontFamily}"
                                                       Foreground="{DynamicResource TextFaintBrush}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>

                                        <!-- Not Draft -->
                                        <StackPanel Orientation="Exampletal">
                                            <TextBlock Width="16" TextAlignment="Center" FontSize="13"
                                                       VerticalAlignment="Center" Margin="0,0,8,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="&#x2717;" />
                                                        <Setter Property="Foreground" Value="{DynamicResource StatusRedBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsNotDraft}" Value="True">
                                                                <Setter Property="Text" Value="&#x2713;" />
                                                                <Setter Property="Foreground" Value="{DynamicResource StatusGreenBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="Not Draft" FontSize="12" FontWeight="Medium"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                                            <TextBlock Text="{Binding DraftReadinessDetail}" FontSize="11"
                                                       FontFamily="{DynamicResource CodeFontFamily}"
                                                       Foreground="{DynamicResource TextFaintBrush}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- DESCRIPTION section card -->
                        <Border Padding="14,14,16,14" Margin="0,0,0,16" CornerRadius="8"
                                Background="{DynamicResource SurfaceRaisedBrush}"
                                BorderBrush="{DynamicResource SubtleBorderBrush}"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="DESCRIPTION" FontSize="11" FontWeight="Bold"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="0,0,0,12" />
                                <!-- Empty placeholder -->
                                <TextBlock Text="No description provided."
                                           FontSize="13" FontStyle="Italic"
                                           Foreground="{DynamicResource TextTertiaryBrush}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Body}" Value="">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <!-- Rendered markdown body -->
                                <RichTextBox IsReadOnly="True" BorderThickness="0"
                                             Background="Transparent"
                                             Foreground="{DynamicResource TextTertiaryBrush}"
                                             FontSize="13"
                                             Padding="0"
                                             infra:MarkdownTextBlock.Markdown="{Binding Body}">
                                    <RichTextBox.Style>
                                        <Style TargetType="RichTextBox">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Body}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </RichTextBox.Style>
                                </RichTextBox>
                            </StackPanel>
                        </Border>

                        <!-- AI REVIEW SUMMARY section card -->
                        <Border Padding="14,14,16,14" Margin="0,0,0,16" CornerRadius="8"
                                Background="{DynamicResource SurfaceRaisedBrush}"
                                BorderBrush="{DynamicResource SubtleBorderBrush}"
                                BorderThickness="1"
                                Visibility="{Binding HasAiReview, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock Text="AI REVIEW SUMMARY" FontSize="11" FontWeight="Bold"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="0,0,0,12" />
                                <UniformGrid Columns="3" Margin="0">
                                    <!-- Suggestions -->
                                    <Border CornerRadius="6" Padding="8,8,12,8" Margin="0,0,8,0"
                                            Background="{DynamicResource WarningBadgeBackgroundBrush}"
                                            BorderBrush="{DynamicResource WarningBadgeBorderBrush}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="{Binding SuggestionCount}" FontSize="18" FontWeight="Bold"
                                                       FontFamily="{DynamicResource CodeFontFamily}"
                                                       Foreground="{DynamicResource StatusYellowBrush}" />
                                            <TextBlock Text="Suggestions" FontSize="11"
                                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                                       Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <!-- Praise -->
                                    <Border CornerRadius="6" Padding="8,8,12,8" Margin="0,0,8,0"
                                            Background="{DynamicResource SuccessBadgeBackgroundBrush}"
                                            BorderBrush="{DynamicResource SuccessBadgeBorderBrush}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="{Binding PraiseCount}" FontSize="18" FontWeight="Bold"
                                                       FontFamily="{DynamicResource CodeFontFamily}"
                                                       Foreground="{DynamicResource StatusGreenBrush}" />
                                            <TextBlock Text="Praise" FontSize="11"
                                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                                       Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <!-- Other -->
                                    <Border CornerRadius="6" Padding="8,8,12,8"
                                            Background="{DynamicResource SurfaceHoverBrush}"
                                            BorderBrush="{DynamicResource SubtleBorderBrush}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="{Binding OtherReviewCount}" FontSize="18" FontWeight="Bold"
                                                       FontFamily="{DynamicResource CodeFontFamily}"
                                                       Foreground="{DynamicResource TextTertiaryBrush}" />
                                            <TextBlock Text="Other" FontSize="11"
                                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                                       Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <!-- LABELS section card -->
                        <Border Padding="14,14,16,14" Margin="0,0,0,16" CornerRadius="8"
                                Background="{DynamicResource SurfaceRaisedBrush}"
                                BorderBrush="{DynamicResource SubtleBorderBrush}"
                                BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Labels.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="LABELS" FontSize="11" FontWeight="Bold"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           Margin="0,0,0,12" />
                                <ItemsControl ItemsSource="{Binding Labels}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Exampletal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="4" Padding="10,3" Margin="0,0,6,4"
                                                    Background="{Binding Converter={StaticResource LabelToVariant}, ConverterParameter=bg}"
                                                    BorderBrush="{Binding Converter={StaticResource LabelToVariant}, ConverterParameter=border}"
                                                    BorderThickness="1">
                                                <TextBlock Text="{Binding}" FontSize="12" FontWeight="Medium"
                                                           FontFamily="{DynamicResource CodeFontFamily}"
                                                           Foreground="{Binding Converter={StaticResource LabelToVariant}, ConverterParameter=fg}" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- CHECKS TAB -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="24,18,18,24">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource DetailScrollBar}" />
                    </ScrollViewer.Resources>
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveTab}" Value="Checks">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <StackPanel>
                        <TextBlock Text="Loading checks..."
                                   FontSize="11" FontStyle="Italic"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   Visibility="{Binding IsChecksLoading, Converter={StaticResource BoolToVis}}" />
                        <ItemsControl ItemsSource="{Binding CheckRuns}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10,10,14,10" Margin="0,0,0,6" CornerRadius="6"
                                            BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource CheckPassedBgBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource CheckPassedBorderBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsFailed}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource CheckFailedBgBrush}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource CheckFailedBorderBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <!-- Status icon -->
                                            <Ellipse Grid.Column="0" Width="8" Height="8"
                                                     Margin="0,0,10,0" VerticalAlignment="Center">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="{DynamicResource StatusYellowBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                                                                <Setter Property="Fill" Value="{DynamicResource StatusGreenBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsFailed}" Value="True">
                                                                <Setter Property="Fill" Value="{DynamicResource StatusRedBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                       FontSize="13" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <!-- Empty state -->
                        <TextBlock FontSize="13" Foreground="{DynamicResource TextTertiaryBrush}"
                                   ExampletalAlignment="Center" Margin="0,20,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding CheckRuns.Count}" Value="0" />
                                                <Condition Binding="{Binding IsChecksLoading}" Value="False" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <Run Text="&#x2713; " Foreground="{DynamicResource StatusGreenBrush}" />
                            <Run Text="All checks passing" />
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>

                <!-- REVIEWS TAB -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveTab}" Value="Reviews">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Sort bar + Comment list -->
                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Margin="24,18,18,4">
                        <ScrollViewer.Resources>
                            <Style TargetType="ScrollBar" BasedOn="{StaticResource DetailScrollBar}" />
                        </ScrollViewer.Resources>
                        <StackPanel>
                            <!-- Sort bar -->
                            <StackPanel Orientation="Exampletal" Margin="0,0,0,10">
                                <TextBlock Text="Sort:" FontSize="11" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,8,0" />
                                <StackPanel Orientation="Exampletal">
                                    <StackPanel.Resources>
                                        <Style x:Key="SortChip" TargetType="Button">
                                            <Setter Property="FontSize" Value="11" />
                                            <Setter Property="Padding" Value="8,3" />
                                            <Setter Property="Margin" Value="0,0,4,0" />
                                            <Setter Property="Cursor" Value="Hand" />
                                            <Setter Property="BorderThickness" Value="1" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource SubtleBorderBrush}" />
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter ExampletalAlignment="Center" VerticalAlignment="Center" />
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </StackPanel.Resources>
                                    <Button Content="Newest" Command="{Binding SetReviewSortCommand}" CommandParameter="Newest">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SortChip}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ReviewSortMode}" Value="Newest">
                                                        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="Oldest" Command="{Binding SetReviewSortCommand}" CommandParameter="Oldest">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SortChip}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ReviewSortMode}" Value="Oldest">
                                                        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="Severity" Command="{Binding SetReviewSortCommand}" CommandParameter="Severity">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SortChip}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ReviewSortMode}" Value="Severity">
                                                        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="File" Command="{Binding SetReviewSortCommand}" CommandParameter="File">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SortChip}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ReviewSortMode}" Value="File">
                                                        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Text="Loading reviews..."
                                       FontSize="11" FontStyle="Italic"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       Visibility="{Binding IsCommentsLoading, Converter={StaticResource BoolToVis}}" />
                            <ItemsControl ItemsSource="{Binding AllComments}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="14,12" Margin="0,0,0,8" CornerRadius="8"
                                                Background="{DynamicResource SurfaceRaisedBrush}"
                                                BorderBrush="{DynamicResource SubtleBorderBrush}"
                                                BorderThickness="1">
                                            <StackPanel>
                                                <StackPanel Orientation="Exampletal">
                                                    <TextBlock Text="{Binding Author}" FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                                    <TextBlock FontSize="10" Margin="10,0,0,0"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource TextTertiaryBrush}"
                                                               Text="{Binding CreatedAt, StringFormat='{}{0:MMM d, yyyy HH:mm}'}" />
                                                    <!-- Severity badge -->
                                                    <Border CornerRadius="4" Padding="6,2" Margin="8,0,0,0"
                                                            VerticalAlignment="Center">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Severity}" Value="Critical">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <Setter Property="Background" Value="{DynamicResource ErrorBadgeBackgroundBrush}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Severity}" Value="Suggestion">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <Setter Property="Background" Value="{DynamicResource WarningBadgeBackgroundBrush}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Severity}" Value="Praise">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                        <Setter Property="Background" Value="{DynamicResource SuccessBadgeBackgroundBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock FontSize="10" FontWeight="Bold">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Severity}" Value="Critical">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                            <Setter Property="Text" Value="CRITICAL" />
                                                                            <Setter Property="Foreground" Value="{DynamicResource ErrorBadgeForegroundBrush}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Severity}" Value="Suggestion">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                            <Setter Property="Text" Value="SUGGESTION" />
                                                                            <Setter Property="Foreground" Value="{DynamicResource WarningBadgeForegroundBrush}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Severity}" Value="Praise">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                            <Setter Property="Text" Value="PRAISE" />
                                                                            <Setter Property="Foreground" Value="{DynamicResource SuccessBadgeForegroundBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>
                                                </StackPanel>
                                                <!-- File reference for review comments -->
                                                <TextBlock FontSize="10" Margin="0,4,0,0"
                                                           FontFamily="{DynamicResource CodeFontFamily}"
                                                           Foreground="{DynamicResource TextTertiaryBrush}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding FilePath}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                    <Run Text="{Binding FilePath, Mode=OneWay}" />
                                                    <Run Text=":" /><Run Text="{Binding LineNumber, Mode=OneWay}" />
                                                </TextBlock>
                                                <!-- Comment body (markdown) -->
                                                <RichTextBox IsReadOnly="True" BorderThickness="0"
                                                             Background="Transparent"
                                                             Foreground="{DynamicResource TextPrimaryBrush}"
                                                             FontSize="12.5" Margin="0,6,0,0"
                                                             Padding="0"
                                                             infra:MarkdownTextBlock.Markdown="{Binding Body}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <!-- Empty state -->
                            <TextBlock Text="No reviews yet" FontSize="13"
                                       Foreground="{DynamicResource TextGhostBrush}"
                                       ExampletalAlignment="Center" Margin="0,24,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding AllComments.Count}" Value="0" />
                                                    <Condition Binding="{Binding IsCommentsLoading}" Value="False" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible" />
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Comment input + review actions -->
                    <Border Grid.Row="1" Padding="24,8,24,12"
                            BorderThickness="0,1,0,0" BorderBrush="{DynamicResource SeparatorBrush}">
                        <StackPanel>
                            <!-- Comment input -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding NewCommentText, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="12" Padding="8,6"
                                         Background="{DynamicResource SurfaceBrush}"
                                         Foreground="{DynamicResource TextPrimaryBrush}"
                                         BorderBrush="{DynamicResource SubtleBorderBrush}"
                                         BorderThickness="1"
                                         AcceptsReturn="True" MaxHeight="80"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto" />
                                <Button Grid.Column="1" Content="Comment"
                                        Command="{Binding PostCommentCommand}"
                                        Background="{DynamicResource AccentBrush}"
                                        Foreground="{DynamicResource AccentForegroundBrush}"
                                        Style="{StaticResource DetailActionButton}"
                                        Margin="6,0,0,0" VerticalAlignment="Bottom" />
                            </Grid>
                            <!-- Review actions -->
                            <StackPanel Orientation="Exampletal">
                                <Button Content="&#x2713; Approve"
                                        Command="{Binding SubmitReviewCommand}"
                                        CommandParameter="APPROVE"
                                        Background="{DynamicResource SuccessBadgeBackgroundBrush}"
                                        Foreground="{DynamicResource SuccessBadgeForegroundBrush}"
                                        Style="{StaticResource DetailActionButton}" />
                                <Button Content="&#x2717; Request Changes"
                                        Command="{Binding SubmitReviewCommand}"
                                        CommandParameter="REQUEST_CHANGES"
                                        Background="{DynamicResource ErrorBadgeBackgroundBrush}"
                                        Foreground="{DynamicResource ErrorBadgeForegroundBrush}"
                                        Style="{StaticResource DetailActionButton}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- ===== TOAST ===== -->
            <Border Grid.Row="3" ExampletalAlignment="Center" Margin="0,0,0,8"
                    CornerRadius="6" Padding="12,6"
                    Background="{DynamicResource SurfaceRaisedBrush}"
                    BorderBrush="{DynamicResource SubtleBorderBrush}"
                    BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ToastMessage}" Value="">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding ToastMessage}" FontSize="11"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
            </Border>
        </Grid>
    </Border>
</Window>
