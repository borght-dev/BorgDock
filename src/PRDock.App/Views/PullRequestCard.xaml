<UserControl x:Class="PRDock.App.Views.PullRequestCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:PRDock.App.Converters">

    <UserControl.Resources>
        <converters:StatusToColorConverter x:Key="StatusToColorConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Border Background="{DynamicResource CardBackgroundBrush}"
            CornerRadius="6"
            Margin="0,0,0,8"
            Padding="12">
        <Grid>
            <!-- My PR left border indicator -->
            <Rectangle Width="3"
                       ExampletalAlignment="Left"
                       Margin="-12,0,0,0"
                       RadiusX="1.5" RadiusY="1.5"
                       Fill="{DynamicResource CardBorderMyPRBrush}"
                       Visibility="{Binding IsMyPr, Converter={StaticResource BoolToVis}}" />

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Row 0: Status dot + Title + PR number -->
                <StackPanel Grid.Row="0" Orientation="Exampletal">
                    <Ellipse Width="12" Height="12"
                             VerticalAlignment="Center"
                             Margin="0,0,8,0"
                             Fill="{Binding StatusDotColor, Converter={StaticResource StatusToColorConverter}}" />
                    <TextBlock Text="{Binding Title}"
                               FontWeight="SemiBold"
                               FontSize="13"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="280"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextPrimaryBrush}" />
                    <TextBlock VerticalAlignment="Center"
                               Margin="6,0,0,0"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}">
                        <Run Text="#" /><Run Text="{Binding Number, Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>

                <!-- Row 1: branch -> target -->
                <TextBlock Grid.Row="1"
                           FontSize="11"
                           Margin="20,2,0,0"
                           Foreground="{DynamicResource TextSecondaryBrush}">
                    <Run Text="{Binding HeadRef, Mode=OneWay}" />
                    <Run Text=" &#x2192; " />
                    <Run Text="{Binding BaseRef, Mode=OneWay}" />
                </TextBlock>

                <!-- Row 2: author + age -->
                <TextBlock Grid.Row="2"
                           FontSize="11"
                           Margin="20,2,0,0"
                           Foreground="{DynamicResource TextSecondaryBrush}">
                    <Run Text="by " /><Run Text="{Binding AuthorLogin, Mode=OneWay}" />
                    <Run Text=" &#x00B7; " />
                    <Run Text="{Binding Age, Mode=OneWay}" />
                </TextBlock>

                <!-- Row 3: Check chips -->
                <WrapPanel Grid.Row="3" Margin="20,4,0,0" Orientation="Exampletal">
                    <!-- Failed checks -->
                    <ItemsControl ItemsSource="{Binding FailedChecks}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Exampletal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#33EF4444"
                                        CornerRadius="3"
                                        Padding="5,2"
                                        Margin="0,0,4,4">
                                    <TextBlock FontSize="10" Foreground="#EF4444">
                                        <Run Text="&#x2717; " /><Run Text="{Binding Mode=OneWay}" />
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Pending checks -->
                    <ItemsControl ItemsSource="{Binding PendingChecks}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Exampletal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#33F59E0B"
                                        CornerRadius="3"
                                        Padding="5,2"
                                        Margin="0,0,4,4">
                                    <TextBlock FontSize="10" Foreground="#F59E0B">
                                        <Run Text="&#x23F3; " /><Run Text="{Binding Mode=OneWay}" />
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Passed summary chip -->
                    <Border Background="#3322C55E"
                            CornerRadius="3"
                            Padding="5,2"
                            Margin="0,0,4,4">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CheckSummary}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock FontSize="10" Foreground="#22C55E">
                            <Run Text="&#x2713; " /><Run Text="{Binding CheckSummary, Mode=OneWay}" />
                        </TextBlock>
                    </Border>
                </WrapPanel>

                <!-- Row 4: Review badge + merge conflict -->
                <StackPanel Grid.Row="4" Orientation="Exampletal" Margin="20,2,0,0">
                    <!-- Review badge -->
                    <Border CornerRadius="3"
                            Padding="5,2"
                            Margin="0,0,4,0"
                            Background="{DynamicResource BackgroundBrush}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ReviewBadgeText}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}">
                            <Run Text="&#x1F441; " /><Run Text="{Binding ReviewBadgeText, Mode=OneWay}" />
                        </TextBlock>
                    </Border>

                    <!-- Merge conflict -->
                    <Border CornerRadius="3"
                            Padding="5,2"
                            Background="#33EF4444"
                            Visibility="{Binding HasMergeConflict, Converter={StaticResource BoolToVis}}">
                        <TextBlock FontSize="10" Foreground="#EF4444">
                            <Run Text="&#x26A0; Merge conflict" />
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
