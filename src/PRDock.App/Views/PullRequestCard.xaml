<UserControl x:Class="PRDock.App.Views.PullRequestCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:PRDock.App.Converters"
             xmlns:infra="clr-namespace:PRDock.App.Infrastructure">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:StatusToColorConverter x:Key="StatusToColor" />
        <conv:MergeScoreToColorConverter x:Key="ScoreToColor" />
        <conv:ScoreToArcGeometryConverter x:Key="ScoreToArc" />
        <conv:LabelToVariantConverter x:Key="LabelToVariant" />
        <conv:InitialsToColorConverter x:Key="InitialsToColor" />
        <conv:BoolToAngleConverter x:Key="BoolToAngle" />
    </UserControl.Resources>

    <StackPanel>
        <!-- Section header (e.g., "Recently Closed") -->
        <Border Padding="18,10,18,6"
                BorderBrush="{DynamicResource SeparatorBrush}"
                BorderThickness="0,1,0,0">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding SectionHeader}" Value="">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding SectionHeader}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding SectionHeader}"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextMutedBrush}"
                       FontFamily="{DynamicResource CodeFontFamily}" />
        </Border>

        <!-- Main clickable row -->
        <Border x:Name="RowBorder"
                Cursor="Hand"
                BorderThickness="2,0,0,0"
                Padding="13,13,18,13"
                MouseLeftButtonUp="Row_Click">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="BorderBrush" Value="Transparent" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Opacity" Value="1.0" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsMyPr}" Value="True">
                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            <Setter Property="Background" Value="{DynamicResource SelectedRowBgBrush}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsDraft}" Value="True">
                            <Setter Property="Opacity" Value="0.65" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsFocused}" Value="True">
                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="38" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" MinWidth="110" />
                </Grid.ColumnDefinitions>

                <!-- Column 0: Merge Score Ring -->
                <Grid Grid.Column="0" Width="38" Height="38" VerticalAlignment="Top">
                    <!-- Canvas for absolute-coordinate ring rendering -->
                    <Canvas>
                        <Ellipse Canvas.Left="5" Canvas.Top="5" Width="28" Height="28"
                                 StrokeThickness="3"
                                 Stroke="{DynamicResource SurfaceRaisedBrush}"
                                 Fill="Transparent" />
                        <Path StrokeThickness="3"
                              Stroke="{Binding MergeScore, Converter={StaticResource ScoreToColor}}"
                              Data="{Binding MergeScore, Converter={StaticResource ScoreToArc}}"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round" />
                    </Canvas>
                    <!-- Score text -->
                    <TextBlock Text="{Binding MergeScore}"
                               FontSize="10" FontWeight="Bold"
                               FontFamily="{DynamicResource CodeFontFamily}"
                               Foreground="{Binding MergeScore, Converter={StaticResource ScoreToColor}}"
                               ExampletalAlignment="Center" VerticalAlignment="Center" />
                </Grid>

                <!-- Column 1: PR Info -->
                <StackPanel Grid.Column="1" Margin="14,0,0,0">
                    <!-- Row 1: Status dot + PR number + Title + expand arrow -->
                    <WrapPanel Margin="0,0,0,6">
                        <!-- Status dot (8px circle) -->
                        <Ellipse Width="8" Height="8" Margin="0,4,8,0" VerticalAlignment="Top"
                                 Fill="{Binding StatusDotColor, Converter={StaticResource StatusToColor}}" />

                        <!-- PR Number -->
                        <TextBlock FontFamily="{DynamicResource CodeFontFamily}"
                                   FontSize="12" FontWeight="Medium"
                                   Foreground="{DynamicResource TextFaintBrush}"
                                   Margin="0,0,8,0">
                            <Run Text="#" /><Run Text="{Binding Number, Mode=OneWay}" />
                        </TextBlock>

                        <!-- Title -->
                        <TextBlock Text="{Binding Title}"
                                   FontSize="13.5" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   MaxWidth="500" />

                        <!-- Expand arrow -->
                        <TextBlock Text="&#x25BE;" FontSize="10"
                                   Foreground="{DynamicResource TextGhostBrush}"
                                   Margin="4,2,0,0"
                                   RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform>
                                <RotateTransform Angle="{Binding IsExpanded, Converter={StaticResource BoolToAngle}}" />
                            </TextBlock.RenderTransform>
                        </TextBlock>
                    </WrapPanel>

                    <!-- Row 2: Badges (labels + conflicts + ready + draft) -->
                    <WrapPanel Margin="0,0,0,6">
                        <!-- Draft badge -->
                        <Border Visibility="{Binding IsDraft, Converter={StaticResource BoolToVis}}"
                                Background="{DynamicResource DraftBadgeBackgroundBrush}"
                                BorderBrush="{DynamicResource DraftBadgeBorderBrush}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="8,2" Margin="0,0,6,3">
                            <TextBlock Text="draft" FontSize="11" FontWeight="Medium"
                                       FontFamily="{DynamicResource CodeFontFamily}"
                                       Foreground="{DynamicResource DraftBadgeForegroundBrush}" />
                        </Border>

                        <!-- Label badges (from Labels collection) -->
                        <ItemsControl ItemsSource="{Binding Labels}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding Converter={StaticResource LabelToVariant}, ConverterParameter=bg}"
                                            BorderBrush="{Binding Converter={StaticResource LabelToVariant}, ConverterParameter=border}"
                                            BorderThickness="1" CornerRadius="4"
                                            Padding="8,2" Margin="0,0,6,3">
                                        <TextBlock Text="{Binding}" FontSize="11" FontWeight="Medium"
                                                   FontFamily="{DynamicResource CodeFontFamily}"
                                                   Foreground="{Binding Converter={StaticResource LabelToVariant}, ConverterParameter=fg}" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Conflict badge -->
                        <Border Visibility="{Binding HasMergeConflict, Converter={StaticResource BoolToVis}}"
                                Background="{DynamicResource ErrorBadgeBackgroundBrush}"
                                BorderBrush="{DynamicResource ErrorBadgeBorderBrush}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="8,2" Margin="0,0,6,3">
                            <TextBlock FontSize="11" FontWeight="Medium"
                                       FontFamily="{DynamicResource CodeFontFamily}"
                                       Foreground="{DynamicResource ErrorBadgeForegroundBrush}">
                                <Run Text="&#x26A1;" /><Run Text=" conflicts" />
                            </TextBlock>
                        </Border>

                        <!-- Ready badge -->
                        <Border Visibility="{Binding HasAllChecksPassed, Converter={StaticResource BoolToVis}}"
                                Background="{DynamicResource SuccessBadgeBackgroundBrush}"
                                BorderBrush="{DynamicResource SuccessBadgeBorderBrush}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="8,2" Margin="0,0,6,3">
                            <TextBlock FontSize="11" FontWeight="Medium"
                                       FontFamily="{DynamicResource CodeFontFamily}"
                                       Foreground="{DynamicResource SuccessBadgeForegroundBrush}"
                                       Text="&#x2713; ready" />
                        </Border>

                        <!-- Closure badge -->
                        <Border Visibility="{Binding IsClosed, Converter={StaticResource BoolToVis}}"
                                CornerRadius="4" Padding="8,2" Margin="0,0,6,3"
                                BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource ErrorBadgeBackgroundBrush}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource ErrorBadgeBorderBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ClosureState}" Value="Merged">
                                            <Setter Property="Background" Value="{DynamicResource SuccessBadgeBackgroundBrush}" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource SuccessBadgeBorderBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ClosureState}" Value="Closed">
                                            <Setter Property="Background" Value="{DynamicResource NeutralBadgeBackgroundBrush}" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource NeutralBadgeBorderBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding ClosureBadgeText}" FontSize="11" FontWeight="Medium"
                                       FontFamily="{DynamicResource CodeFontFamily}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource ErrorBadgeForegroundBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ClosureState}" Value="Merged">
                                                <Setter Property="Foreground" Value="{DynamicResource SuccessBadgeForegroundBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ClosureState}" Value="Closed">
                                                <Setter Property="Foreground" Value="{DynamicResource NeutralBadgeForegroundBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </WrapPanel>

                    <!-- Row 3: Author avatar + name + age + diff stats -->
                    <StackPanel Orientation="Exampletal">
                        <!-- Author avatar circle -->
                        <Grid Width="18" Height="18" Margin="0,0,5,0">
                            <Ellipse Fill="{Binding AuthorInitials, Converter={StaticResource InitialsToColor}}" />
                            <TextBlock Text="{Binding AuthorInitials}"
                                       FontSize="7" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AvatarTextBrush}"
                                       ExampletalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>

                        <TextBlock FontSize="11.5"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   VerticalAlignment="Center">
                            <Run Text="{Binding AuthorLogin, Mode=OneWay}" />
                        </TextBlock>

                        <TextBlock Text=" &#x00B7; " Foreground="{DynamicResource TextGhostBrush}"
                                   FontSize="11.5" VerticalAlignment="Center" />

                        <TextBlock Text="{Binding Age}"
                                   FontFamily="{DynamicResource CodeFontFamily}"
                                   FontSize="11" Foreground="{DynamicResource TextFaintBrush}"
                                   VerticalAlignment="Center" />

                        <TextBlock Text=" &#x00B7; " Foreground="{DynamicResource TextGhostBrush}"
                                   FontSize="11.5" VerticalAlignment="Center" />

                        <TextBlock FontFamily="{DynamicResource CodeFontFamily}"
                                   FontSize="11" VerticalAlignment="Center">
                            <Run Text="+" Foreground="{DynamicResource StatusGreenBrush}" /><Run Text="{Binding Additions, Mode=OneWay}" Foreground="{DynamicResource StatusGreenBrush}" />
                            <Run Text=" / " Foreground="{DynamicResource TextGhostBrush}" />
                            <Run Text="-" Foreground="{DynamicResource StatusRedBrush}" /><Run Text="{Binding Deletions, Mode=OneWay}" Foreground="{DynamicResource StatusRedBrush}" />
                        </TextBlock>

                    </StackPanel>
                </StackPanel>

                <!-- Column 2: Stats (progress bar, review status, comments) -->
                <StackPanel Grid.Column="2" ExampletalAlignment="Right" VerticalAlignment="Top">
                    <!-- Progress bar + count -->
                    <Grid Width="100" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <!-- Thin progress bar -->
                        <Grid Grid.Column="0" Height="3" VerticalAlignment="Center" Margin="0,0,8,0">
                            <ProgressBar Minimum="0" Maximum="{Binding TotalChecks}"
                                         Value="{Binding PassedChecks}"
                                         Height="3" Background="Transparent"
                                         BorderThickness="0">
                                <ProgressBar.Style>
                                    <Style TargetType="ProgressBar">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ProgressBar">
                                                    <Grid>
                                                        <Border CornerRadius="2" Background="{DynamicResource SurfaceRaisedBrush}" />
                                                        <Border x:Name="PART_Track" />
                                                        <Border x:Name="PART_Indicator"
                                                                CornerRadius="2"
                                                                ExampletalAlignment="Left"
                                                                Background="{DynamicResource StatusGreenBrush}" />
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding StatusDotColor}" Value="red">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ProgressBar">
                                                            <Grid>
                                                                <Border CornerRadius="2" Background="{DynamicResource SurfaceRaisedBrush}" />
                                                                <Border x:Name="PART_Track" />
                                                                <Border x:Name="PART_Indicator"
                                                                        CornerRadius="2"
                                                                        ExampletalAlignment="Left"
                                                                        Background="{DynamicResource StatusRedBrush}" />
                                                            </Grid>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusDotColor}" Value="yellow">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ProgressBar">
                                                            <Grid>
                                                                <Border CornerRadius="2" Background="{DynamicResource SurfaceRaisedBrush}" />
                                                                <Border x:Name="PART_Track" />
                                                                <Border x:Name="PART_Indicator"
                                                                        CornerRadius="2"
                                                                        ExampletalAlignment="Left"
                                                                        Background="{DynamicResource StatusYellowBrush}" />
                                                            </Grid>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ProgressBar.Style>
                            </ProgressBar>
                        </Grid>
                        <!-- Count text -->
                        <TextBlock Grid.Column="1"
                                   FontFamily="{DynamicResource CodeFontFamily}"
                                   FontSize="11" FontWeight="Medium"
                                   VerticalAlignment="Center">
                            <Run Text="{Binding PassedChecks, Mode=OneWay}" /><Run Text="/" /><Run Text="{Binding TotalChecks, Mode=OneWay}" />
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource StatusGreenBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding StatusDotColor}" Value="red">
                                            <Setter Property="Foreground" Value="{DynamicResource StatusRedBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding StatusDotColor}" Value="yellow">
                                            <Setter Property="Foreground" Value="{DynamicResource StatusYellowBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <!-- Review status badge text -->
                    <TextBlock Text="{Binding ReviewBadgeText}"
                               FontSize="11" FontStyle="Italic"
                               Foreground="{DynamicResource TextGhostBrush}"
                               ExampletalAlignment="Right" Margin="0,0,0,4" />

                    <!-- Comment count (right-aligned to match check count above) -->
                    <StackPanel Orientation="Exampletal" ExampletalAlignment="Right">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CommentCount}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="&#xE8F2;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,4,0" />
                        <TextBlock Text="{Binding CommentCount}"
                                   FontSize="11" Foreground="{DynamicResource TextMutedBrush}" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Expanded Content (visible when IsExpanded=true) -->
        <Border Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}"
                Background="{DynamicResource ExpandedRowBgBrush}"
                BorderBrush="{DynamicResource SeparatorBrush}"
                BorderThickness="0,0,0,1"
                Padding="14,14,18,16">
            <!-- Offset content to align with column 1 (roughly 38+14 = 52px from left) -->
            <StackPanel Margin="52,0,0,0">

                <!-- Branch info -->
                <WrapPanel Margin="0,0,0,12">
                    <Border Background="{DynamicResource BranchBadgeBgBrush}"
                            BorderBrush="{DynamicResource BranchBadgeBorderBrush}"
                            BorderThickness="1" CornerRadius="4" Padding="7,2" Margin="0,0,8,0">
                        <TextBlock Text="{Binding HeadRef}"
                                   FontFamily="{DynamicResource CodeFontFamily}"
                                   FontSize="11" Foreground="{DynamicResource AccentBrush}" />
                    </Border>
                    <TextBlock Text="&#x2192;" Foreground="{DynamicResource TextGhostBrush}"
                               FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <Border Background="{DynamicResource TargetBadgeBgBrush}"
                            BorderBrush="{DynamicResource TargetBadgeBorderBrush}"
                            BorderThickness="1" CornerRadius="4" Padding="7,2" Margin="0,0,8,0">
                        <TextBlock Text="{Binding BaseRef}"
                                   FontFamily="{DynamicResource CodeFontFamily}"
                                   FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}" />
                    </Border>
                    <TextBlock Foreground="{DynamicResource TextGhostBrush}" FontSize="11" VerticalAlignment="Center" Margin="4,0">&#x00B7;</TextBlock>
                    <TextBlock FontFamily="{DynamicResource CodeFontFamily}" FontSize="11"
                               Foreground="{DynamicResource TextFaintBrush}" VerticalAlignment="Center">
                        <Run Text="{Binding CommitCount, Mode=OneWay}" /><Run Text=" commits" />
                    </TextBlock>
                    <TextBlock Foreground="{DynamicResource TextGhostBrush}" FontSize="11" VerticalAlignment="Center" Margin="4,0">&#x00B7;</TextBlock>
                    <TextBlock FontFamily="{DynamicResource CodeFontFamily}" FontSize="11" VerticalAlignment="Center">
                        <Run Text="+" Foreground="{DynamicResource StatusGreenBrush}" /><Run Text="{Binding Additions, Mode=OneWay}" Foreground="{DynamicResource StatusGreenBrush}" />
                        <Run Text=" / " Foreground="{DynamicResource TextGhostBrush}" />
                        <Run Text="-" Foreground="{DynamicResource StatusRedBrush}" /><Run Text="{Binding Deletions, Mode=OneWay}" Foreground="{DynamicResource StatusRedBrush}" />
                    </TextBlock>
                    <TextBlock Foreground="{DynamicResource TextGhostBrush}" FontSize="11" VerticalAlignment="Center" Margin="4,0">&#x00B7;</TextBlock>
                    <TextBlock FontFamily="{DynamicResource CodeFontFamily}" FontSize="11"
                               Foreground="{DynamicResource TextFaintBrush}" VerticalAlignment="Center">
                        <Run Text="{Binding FilesChanged, Mode=OneWay}" /><Run Text=" files" />
                    </TextBlock>
                </WrapPanel>

                <!-- Merge Readiness (compact) -->
                <Border Padding="10,10,12,10" Margin="0,0,0,12" CornerRadius="6"
                        Background="{DynamicResource SurfaceRaisedBrush}"
                        BorderBrush="{DynamicResource SubtleBorderBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Merge score ring -->
                        <Grid Grid.Column="0" Width="42" Height="42" Margin="0,0,12,0"
                              VerticalAlignment="Center">
                            <Canvas Width="38" Height="38"
                                    ExampletalAlignment="Center" VerticalAlignment="Center">
                                <Ellipse Canvas.Left="5" Canvas.Top="5"
                                         Width="28" Height="28"
                                         Stroke="{DynamicResource SubtleBorderBrush}"
                                         StrokeThickness="2.5" Fill="Transparent" />
                                <Path Data="{Binding MergeScore, Converter={StaticResource ScoreToArc}}"
                                      Stroke="{Binding MergeScore, Converter={StaticResource ScoreToColor}}"
                                      StrokeThickness="2.5"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" />
                            </Canvas>
                            <TextBlock Text="{Binding MergeScore}"
                                       ExampletalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="10" FontWeight="Bold"
                                       FontFamily="{DynamicResource CodeFontFamily}"
                                       Foreground="{Binding MergeScore, Converter={StaticResource ScoreToColor}}" />
                        </Grid>

                        <!-- Readiness checklist -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <!-- CI Checks -->
                            <StackPanel Orientation="Exampletal" Margin="0,0,0,3">
                                <TextBlock Width="14" TextAlignment="Center" FontSize="11"
                                           VerticalAlignment="Center" Margin="0,0,6,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="&#x2717;" />
                                            <Setter Property="Foreground" Value="{DynamicResource StatusRedBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasAllChecksPassed}" Value="True">
                                                    <Setter Property="Text" Value="&#x2713;" />
                                                    <Setter Property="Foreground" Value="{DynamicResource StatusGreenBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="CI Checks" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock FontSize="10" FontFamily="{DynamicResource CodeFontFamily}"
                                           Foreground="{DynamicResource TextFaintBrush}" VerticalAlignment="Center">
                                    <Run Text="{Binding PassedChecks, Mode=OneWay}" /><Run Text="/" /><Run Text="{Binding TotalChecks, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>
                            <!-- Approvals -->
                            <StackPanel Orientation="Exampletal" Margin="0,0,0,3">
                                <TextBlock Width="14" TextAlignment="Center" FontSize="11"
                                           VerticalAlignment="Center" Margin="0,0,6,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="&#x2713;" />
                                            <Setter Property="Foreground" Value="{DynamicResource StatusGreenBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ApprovalCount}" Value="0">
                                                    <Setter Property="Text" Value="&#x2717;" />
                                                    <Setter Property="Foreground" Value="{DynamicResource StatusRedBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="Approvals" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock FontSize="10" FontFamily="{DynamicResource CodeFontFamily}"
                                           Foreground="{DynamicResource TextFaintBrush}" VerticalAlignment="Center"
                                           Text="{Binding ApprovalCount}" />
                            </StackPanel>
                            <!-- No Conflicts -->
                            <StackPanel Orientation="Exampletal" Margin="0,0,0,3">
                                <TextBlock Width="14" TextAlignment="Center" FontSize="11"
                                           VerticalAlignment="Center" Margin="0,0,6,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="&#x2713;" />
                                            <Setter Property="Foreground" Value="{DynamicResource StatusGreenBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasMergeConflict}" Value="True">
                                                    <Setter Property="Text" Value="&#x2717;" />
                                                    <Setter Property="Foreground" Value="{DynamicResource StatusRedBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="No Conflicts" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            </StackPanel>
                            <!-- Not Draft -->
                            <StackPanel Orientation="Exampletal">
                                <TextBlock Width="14" TextAlignment="Center" FontSize="11"
                                           VerticalAlignment="Center" Margin="0,0,6,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="&#x2713;" />
                                            <Setter Property="Foreground" Value="{DynamicResource StatusGreenBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDraft}" Value="True">
                                                    <Setter Property="Text" Value="&#x2717;" />
                                                    <Setter Property="Foreground" Value="{DynamicResource StatusRedBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="Not Draft" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Description (constrained height with scrollbar) -->
                <RichTextBox IsReadOnly="True" BorderThickness="0"
                             Background="Transparent"
                             Foreground="{DynamicResource TextTertiaryBrush}"
                             FontSize="12.5" MaxWidth="700" ExampletalAlignment="Left"
                             Padding="0"
                             Margin="0,0,0,14"
                             MaxHeight="200"
                             VerticalScrollBarVisibility="Auto"
                             infra:MarkdownTextBlock.Markdown="{Binding Body}">
                    <RichTextBox.Style>
                        <Style TargetType="RichTextBox">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Body}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </RichTextBox.Style>
                </RichTextBox>

                <!-- Checks section with failed check names -->
                <StackPanel Margin="0,0,0,14">
                    <TextBlock Text="C H E C K S" FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource TextMutedBrush}"
                               Margin="0,0,0,6" />
                    <!-- Progress bar in expanded -->
                    <Grid Width="140" ExampletalAlignment="Left" Height="3" Margin="0,0,0,6">
                        <ProgressBar Minimum="0" Maximum="{Binding TotalChecks}"
                                     Value="{Binding PassedChecks}"
                                     Height="3" Background="Transparent"
                                     BorderThickness="0">
                            <ProgressBar.Style>
                                <Style TargetType="ProgressBar">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ProgressBar">
                                                <Grid>
                                                    <Border CornerRadius="2" Background="{DynamicResource SurfaceRaisedBrush}" />
                                                    <Border x:Name="PART_Track" />
                                                    <Border x:Name="PART_Indicator"
                                                            CornerRadius="2"
                                                            ExampletalAlignment="Left"
                                                            Background="{DynamicResource StatusGreenBrush}" />
                                                </Grid>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding StatusDotColor}" Value="red">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ProgressBar">
                                                        <Grid>
                                                            <Border CornerRadius="2" Background="{DynamicResource SurfaceRaisedBrush}" />
                                                            <Border x:Name="PART_Track" />
                                                            <Border x:Name="PART_Indicator"
                                                                    CornerRadius="2"
                                                                    ExampletalAlignment="Left"
                                                                    Background="{DynamicResource StatusRedBrush}" />
                                                        </Grid>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ProgressBar.Style>
                        </ProgressBar>
                    </Grid>
                    <!-- Check summary text -->
                    <TextBlock Text="{Binding CheckSummary}"
                               FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,0,0,4" />
                    <!-- Failed check names -->
                    <ItemsControl ItemsSource="{Binding FailedChecks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Exampletal" Margin="0,3,0,0">
                                    <Ellipse Width="6" Height="6" Fill="{DynamicResource StatusRedBrush}"
                                             Margin="0,3,6,0" VerticalAlignment="Top" />
                                    <TextBlock Text="{Binding}" FontFamily="{DynamicResource CodeFontFamily}"
                                               FontSize="11" Foreground="{DynamicResource StatusRedBrush}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>

                <!-- Review summary (compact, one-line) -->
                <TextBlock FontSize="11" Margin="0,0,0,14"
                           Foreground="{DynamicResource TextSecondaryBrush}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ReviewSummaryText}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                    <Run Text="&#x1F4CB; " />
                    <Run Text="{Binding ReviewSummaryText, Mode=OneWay}" />
                </TextBlock>

                <!-- Action buttons -->
                <WrapPanel>
                    <!-- Re-run Checks (shown when failing) -->
                    <Button Command="{Binding RerunFailedChecksCommand}"
                            Margin="0,0,8,0" Cursor="Hand"
                            Padding="10,5" FontSize="11" FontWeight="SemiBold"
                            AutomationProperties.AutomationId="RerunFailedChecksButton">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="BtnBorder" Background="Transparent"
                                                    BorderBrush="{DynamicResource AccentBrush}"
                                                    BorderThickness="1" CornerRadius="6"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter ExampletalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="BtnBorder" Property="Opacity" Value="0.85" />
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="BtnBorder" Property="Opacity" Value="0.72" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StatusDotColor}" Value="red">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Exampletal">
                            <TextBlock Text="&#x21BB; " />
                            <TextBlock Text="Re-run Checks" />
                        </StackPanel>
                    </Button>

                    <!-- Fix with Claude (shown when failing) -->
                    <Button Command="{Binding FixWithClaudeCommand}"
                            Margin="0,0,8,0" Cursor="Hand"
                            Padding="10,5" FontSize="11" FontWeight="SemiBold"
                            AutomationProperties.AutomationId="FixWithClaudeButton">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="BtnBorder" Background="Transparent"
                                                    BorderBrush="{DynamicResource PurpleBorderBrush}"
                                                    BorderThickness="1" CornerRadius="6"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter ExampletalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="BtnBorder" Property="Opacity" Value="0.85" />
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="BtnBorder" Property="Opacity" Value="0.72" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="{DynamicResource PurpleBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StatusDotColor}" Value="red">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Exampletal">
                            <TextBlock Text="&#x2726; " FontSize="10" />
                            <TextBlock Text="Fix with Claude" />
                        </StackPanel>
                    </Button>

                    <!-- Monitor with Claude (always visible) -->
                    <Button Command="{Binding MonitorWithClaudeCommand}"
                            Margin="0,0,8,0" Cursor="Hand"
                            Padding="10,5" FontSize="11" FontWeight="SemiBold"
                            AutomationProperties.AutomationId="MonitorWithClaudeButton">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="BtnBorder" Background="Transparent"
                                                    BorderBrush="{DynamicResource PurpleBorderBrush}"
                                                    BorderThickness="1" CornerRadius="6"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter ExampletalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="BtnBorder" Property="Opacity" Value="0.85" />
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="BtnBorder" Property="Opacity" Value="0.72" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="{DynamicResource PurpleBrush}" />
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Exampletal">
                            <TextBlock Text="&#x25B6; " FontSize="10" />
                            <TextBlock Text="Monitor" />
                        </StackPanel>
                    </Button>

                    <!-- Copy for Claude (shown when failing) -->
                    <Button Command="{Binding CopyErrorsForClaudeCommand}"
                            Margin="0,0,8,0" Cursor="Hand"
                            Padding="10,5" FontSize="11" FontWeight="SemiBold"
                            AutomationProperties.AutomationId="CopyForClaudeButton">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="BtnBorder" Background="Transparent"
                                                    BorderBrush="{DynamicResource SubtleBorderBrush}"
                                                    BorderThickness="1" CornerRadius="6"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter ExampletalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="BtnBorder" Property="Opacity" Value="0.85" />
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="BtnBorder" Property="Opacity" Value="0.72" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasFailingChecks}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Exampletal">
                            <TextBlock Text="&#x1F4CB; " FontSize="10" />
                            <TextBlock Text="Copy for Claude" />
                        </StackPanel>
                    </Button>

                    <!-- Bypass merge (shown when CanBypassMerge) -->
                    <Button Command="{Binding BypassMergeCommand}"
                            Margin="0,0,8,0" Cursor="Hand"
                            Padding="10,5" FontSize="11" FontWeight="SemiBold"
                            Visibility="{Binding CanBypassMerge, Converter={StaticResource BoolToVis}}"
                            AutomationProperties.AutomationId="BypassMergeButton">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="BtnBorder"
                                                    Background="{DynamicResource ActionDangerBackgroundBrush}"
                                                    BorderBrush="{DynamicResource ErrorBadgeBorderBrush}"
                                                    BorderThickness="1" CornerRadius="6"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter ExampletalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="BtnBorder" Property="Opacity" Value="0.85" />
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="BtnBorder" Property="Opacity" Value="0.72" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="{DynamicResource ActionDangerForegroundBrush}" />
                            </Style>
                        </Button.Style>
                        <TextBlock Text="Bypass merge" />
                    </Button>

                    <!-- Details (opens PRDetailWindow) -->
                    <Button Command="{Binding OpenDetailViewCommand}"
                            Margin="0,0,8,0" Cursor="Hand"
                            Padding="10,5" FontSize="11" FontWeight="SemiBold"
                            AutomationProperties.AutomationId="OpenDetailViewButton">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="BtnBorder" Background="Transparent"
                                                    BorderBrush="{DynamicResource SubtleBorderBrush}"
                                                    BorderThickness="1" CornerRadius="6"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter ExampletalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="BtnBorder" Property="Opacity" Value="0.85" />
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="BtnBorder" Property="Opacity" Value="0.72" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                            </Style>
                        </Button.Style>
                        <TextBlock Text="Details &#x2192;" />
                    </Button>

                    <!-- Open in GitHub -->
                    <Button Command="{Binding OpenInBrowserCommand}"
                            Cursor="Hand"
                            Padding="10,5" FontSize="11" FontWeight="SemiBold"
                            AutomationProperties.AutomationId="CardOpenBrowserButton">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="BtnBorder" Background="Transparent"
                                                    BorderBrush="{DynamicResource SubtleBorderBrush}"
                                                    BorderThickness="1" CornerRadius="6"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter ExampletalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="BtnBorder" Property="Opacity" Value="0.85" />
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="BtnBorder" Property="Opacity" Value="0.72" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Exampletal">
                            <TextBlock Text="&#x2197; " FontSize="11" />
                            <TextBlock Text="Open in GitHub" />
                        </StackPanel>
                    </Button>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- Bottom separator (when not expanded) -->
        <Border Height="1" Background="{DynamicResource SeparatorBrush}">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
        </Border>
    </StackPanel>
</UserControl>
