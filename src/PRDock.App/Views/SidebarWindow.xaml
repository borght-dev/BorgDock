<Window x:Class="PRDock.App.Views.SidebarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PRDock.App.ViewModels"
        xmlns:views="clr-namespace:PRDock.App.Views"
        xmlns:conv="clr-namespace:PRDock.App.Converters"
        Title="PRDock"
        WindowStyle="None"
        AllowsTransparency="True"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Width="420"
        Background="{DynamicResource BackgroundBrush}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:ExpanderArrowConverter x:Key="ExpanderArrow" />

        <Style x:Key="FilterChipStyle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="ChipBorder"
                                Background="{DynamicResource FilterChipBackgroundBrush}"
                                CornerRadius="12"
                                Padding="12,4"
                                Cursor="Hand">
                            <TextBlock x:Name="ChipText"
                                       Text="{TemplateBinding Content}"
                                       FontSize="12"
                                       Foreground="{DynamicResource FilterChipForegroundBrush}"
                                       ExampletalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ChipBorder" Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="ChipText" Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header row -->
        <Grid Grid.Row="0" Margin="12,10,12,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="PRDock"
                       FontSize="18"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextPrimaryBrush}" />

            <ToggleButton Grid.Column="1"
                          Content="Pin"
                          IsChecked="{Binding IsPinned}"
                          Command="{Binding TogglePinCommand}"
                          Margin="4,0"
                          VerticalAlignment="Center"
                          ToolTip="Pin / Unpin sidebar" />

            <Button Grid.Column="2"
                    Content="_"
                    Command="{Binding MinimizeToBadgeCommand}"
                    Width="28" Height="28"
                    Margin="4,0"
                    VerticalAlignment="Center"
                    ToolTip="Minimize to badge" />

            <Button Grid.Column="3"
                    Content="..."
                    Command="{Binding OpenSettingsCommand}"
                    Width="28" Height="28"
                    Margin="4,0"
                    VerticalAlignment="Center"
                    ToolTip="Settings" />
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="1"
                Background="{DynamicResource CardBackgroundBrush}"
                Padding="12,6"
                Margin="12,0,12,6"
                CornerRadius="4">
            <TextBlock Text="{Binding StatusText}"
                       FontSize="12"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
        </Border>

        <!-- Filter chips row -->
        <StackPanel Grid.Row="2" Orientation="Exampletal" Margin="12,0,12,8">
            <RadioButton Content="All" GroupName="Filter" IsChecked="True"
                         Command="{Binding SetFilterCommand}" CommandParameter="All"
                         Style="{StaticResource FilterChipStyle}" />
            <RadioButton Content="My PRs" GroupName="Filter"
                         Command="{Binding SetFilterCommand}" CommandParameter="My PRs"
                         Style="{StaticResource FilterChipStyle}" Margin="4,0,0,0" />
            <RadioButton Content="Failing" GroupName="Filter"
                         Command="{Binding SetFilterCommand}" CommandParameter="Failing"
                         Style="{StaticResource FilterChipStyle}" Margin="4,0,0,0" />
        </StackPanel>

        <!-- Main content area -->
        <Grid Grid.Row="3">
            <!-- Empty state message -->
            <TextBlock Text="No PRs loaded"
                       FontSize="14"
                       ExampletalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextPrimaryBrush}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding RepoGroups.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Grouped PR list -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="12,0,12,12">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding RepoGroups.Count}" Value="0">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <ItemsControl ItemsSource="{Binding RepoGroups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <!-- Group header: clickable to toggle expand -->
                                <Button Command="{Binding ToggleExpandCommand}"
                                        Background="Transparent" BorderThickness="0"
                                        ExampletalContentAlignment="Stretch"
                                        Cursor="Hand"
                                        Padding="0,6">
                                    <StackPanel Orientation="Exampletal">
                                        <TextBlock Text="{Binding IsExpanded, Converter={StaticResource ExpanderArrow}}"
                                                   FontSize="10"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                                        <TextBlock Text="{Binding RepoFullName}"
                                                   FontWeight="SemiBold"
                                                   FontSize="13"
                                                   Margin="6,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                                        <TextBlock Text="{Binding PrCount, StringFormat='({0})'}"
                                                   FontSize="12"
                                                   Margin="4,0,0,0"
                                                   Opacity="0.6"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                                    </StackPanel>
                                </Button>

                                <!-- PR cards (visible when expanded) -->
                                <ItemsControl ItemsSource="{Binding PullRequests}"
                                              Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource CardBackgroundBrush}"
                                                    CornerRadius="4"
                                                    Padding="10,8"
                                                    Margin="0,2">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="BorderThickness" Value="0" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsMyPr}" Value="True">
                                                                <Setter Property="BorderThickness" Value="3,0,0,0" />
                                                                <Setter Property="BorderBrush" Value="{DynamicResource CardBorderMyPRBrush}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsFocused}" Value="True">
                                                                <Setter Property="BorderThickness" Value="2" />
                                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding Number, StringFormat='#{0}'}"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               Margin="0,0,8,0"
                                                               VerticalAlignment="Top" />

                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding Title}"
                                                                   FontSize="13"
                                                                   TextWrapping="Wrap"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                                                        <TextBlock FontSize="11"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   Margin="0,2,0,0">
                                                            <Run Text="{Binding AuthorLogin, Mode=OneWay}" />
                                                            <Run Text=" · " />
                                                            <Run Text="{Binding Age, Mode=OneWay}" />
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
