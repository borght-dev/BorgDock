<Window x:Class="PRDock.App.Views.SidebarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PRDock.App.ViewModels"
        xmlns:views="clr-namespace:PRDock.App.Views"
        xmlns:conv="clr-namespace:PRDock.App.Converters"
        Title="PRDock"
        WindowStyle="None"
        AllowsTransparency="True"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Width="420"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:ExpanderArrowConverter x:Key="ExpanderArrow" />

        <!-- Thin modern scrollbar -->
        <Style x:Key="ThinScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder"
                                CornerRadius="3"
                                Background="{DynamicResource ScrollbarThumbBrush}"
                                Margin="1,2"
                                Opacity="0.6" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource ScrollbarThumbHoverBrush}" />
                                <Setter TargetName="ThumbBorder" Property="Opacity" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThinScrollBarStyle" TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="6" />
            <Setter Property="MinWidth" Value="6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ThinScrollBarThumbStyle}" />
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FilterChipStyle" TargetType="RadioButton">
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="ChipBorder"
                                Background="{DynamicResource FilterChipBackgroundBrush}"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="14,6"
                                Cursor="Hand">
                            <TextBlock x:Name="ChipText"
                                       Text="{TemplateBinding Content}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource FilterChipForegroundBrush}"
                                       ExampletalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ChipBorder" Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="ChipBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="ChipText" Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ChipBorder" Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsChecked" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ChipBorder" Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="ChipBorder" Property="Opacity" Value="0.9" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource IconButtonBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource IconButtonForegroundBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="HeaderButtonBorder"
                                CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0">
                            <ContentPresenter ExampletalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderButtonBorder" Property="Background" Value="{DynamicResource IconButtonHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="HeaderButtonBorder" Property="Background" Value="{DynamicResource IconButtonPressedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="{DynamicResource IconButtonBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource IconButtonForegroundBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="HeaderToggleBorder"
                                CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0">
                            <ContentPresenter ExampletalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="HeaderToggleBorder" Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderToggleBorder" Property="Background" Value="{DynamicResource IconButtonHoverBrush}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsChecked" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="HeaderToggleBorder" Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter TargetName="HeaderToggleBorder" Property="Opacity" Value="0.9" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GroupHeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6,8" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="ExampletalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="GroupHeaderBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ExampletalAlignment="{TemplateBinding ExampletalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="GroupHeaderBorder" Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header row -->
        <Grid Grid.Row="0" Margin="18,16,18,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Exampletal" VerticalAlignment="Center">
                <TextBlock Text="PRDock"
                           FontSize="18"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
                <!-- Loading spinner (visible when polling) -->
                <TextBlock Text="&#x23F3;" FontSize="11" Margin="8,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />
            </StackPanel>

            <Button Grid.Column="2"
                    Content="&#xE921;"
                    FontFamily="Segoe MDL2 Assets"
                    FontSize="13"
                    Command="{Binding MinimizeToBadgeCommand}"
                    VerticalAlignment="Center"
                    Style="{StaticResource HeaderButtonStyle}"
                    ToolTip="Minimize to badge" />

            <Button Grid.Column="3"
                    Content="&#xE713;"
                    Command="{Binding OpenSettingsCommand}"
                    VerticalAlignment="Center"
                    Style="{StaticResource HeaderButtonStyle}"
                    FontFamily="Segoe MDL2 Assets"
                    FontSize="13"
                    ToolTip="Settings" />
        </Grid>

        <!-- Status text + Filter chips combined row -->
        <Grid Grid.Row="1" Margin="18,4,18,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding StatusText}"
                       FontSize="11"
                       Foreground="{DynamicResource TextTertiaryBrush}" />
        </Grid>

        <!-- Filter chips row -->
        <StackPanel Grid.Row="2" Orientation="Exampletal" Margin="18,6,18,4">
            <RadioButton Content="All" GroupName="Filter" IsChecked="True"
                         Command="{Binding SetFilterCommand}" CommandParameter="All"
                         Style="{StaticResource FilterChipStyle}" />
            <RadioButton Content="My PRs" GroupName="Filter"
                         Command="{Binding SetFilterCommand}" CommandParameter="My PRs"
                         Style="{StaticResource FilterChipStyle}" />
            <RadioButton Content="Failing" GroupName="Filter"
                         Command="{Binding SetFilterCommand}" CommandParameter="Failing"
                         Style="{StaticResource FilterChipStyle}" Margin="0" />
        </StackPanel>

        <!-- Separator -->
        <Border Grid.Row="3" Height="1" Background="{DynamicResource SeparatorBrush}" Margin="18,6,18,6" />

        <!-- Settings flyout (overlays PR list) -->
        <views:SettingsFlyout Grid.Row="4"
                              x:Name="SettingsFlyoutPanel"
                              Panel.ZIndex="10"
                              Visibility="{Binding DataContext.IsSettingsOpen, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}" />

        <!-- Main content area -->
        <Grid Grid.Row="4">
            <!-- Empty state message -->
            <StackPanel ExampletalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="0,0,0,40">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding RepoGroups.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <TextBlock Text="&#xE8B7;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="36"
                           ExampletalAlignment="Center"
                           Foreground="{DynamicResource TextTertiaryBrush}"
                           Margin="0,0,0,12" />
                <TextBlock Text="No pull requests"
                           FontSize="15"
                           FontWeight="SemiBold"
                           ExampletalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}" />
                <TextBlock Text="Configure repositories in settings"
                           FontSize="12"
                           ExampletalAlignment="Center"
                           Margin="0,4,0,0"
                           Foreground="{DynamicResource TextTertiaryBrush}" />
            </StackPanel>

            <!-- Grouped PR list -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="16,0,10,12">
                <ScrollViewer.Resources>
                    <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource ThinScrollBarStyle}" />
                </ScrollViewer.Resources>
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding RepoGroups.Count}" Value="0">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <ItemsControl ItemsSource="{Binding RepoGroups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,6,8">
                                <!-- Group header -->
                                <Button Command="{Binding ToggleExpandCommand}"
                                        Style="{StaticResource GroupHeaderButtonStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding IsExpanded, Converter={StaticResource ExpanderArrow}}"
                                                   FontSize="9"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextTertiaryBrush}" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding RepoFullName}"
                                                   FontWeight="SemiBold"
                                                   FontSize="12"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                                        <Border Grid.Column="2"
                                                Background="{DynamicResource FilterChipBackgroundBrush}"
                                                CornerRadius="10"
                                                Padding="8,2"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding PrCount}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                        </Border>
                                    </Grid>
                                </Button>

                                <!-- PR cards (visible when expanded) -->
                                <ItemsControl ItemsSource="{Binding PullRequests}"
                                              Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <views:PullRequestCard />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
