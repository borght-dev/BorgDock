<Window x:Class="PRDock.App.Views.SidebarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:PRDock.App.Views"
        xmlns:conv="clr-namespace:PRDock.App.Converters"
        xmlns:vm="clr-namespace:PRDock.App.ViewModels"
        Title="PRDock"
        WindowStyle="None"
        AllowsTransparency="True"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        Width="800"
        MinWidth="420"
        MaxWidth="1200"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:ExpanderArrowConverter x:Key="ExpanderArrow" />
        <conv:StringEqualityConverter x:Key="StringEqualityConverter" />

        <!-- Thin modern scrollbar -->
        <Style x:Key="ThinScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder"
                                CornerRadius="3"
                                Background="{DynamicResource ScrollbarThumbBrush}"
                                Margin="1,2"
                                Opacity="0.6" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource ScrollbarThumbHoverBrush}" />
                                <Setter TargetName="ThumbBorder" Property="Opacity" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThinScrollBarStyle" TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="6" />
            <Setter Property="MinWidth" Value="6" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ThinScrollBarThumbStyle}" />
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Filter chip style (RadioButton with badge counts) -->
        <Style x:Key="FilterChipStyle" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="ChipBorder"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="12,5">
                            <ContentPresenter ExampletalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ChipBorder" Property="Background" Value="{DynamicResource AccentSubtleBrush}" />
                                <Setter TargetName="ChipBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsChecked" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ChipBorder" Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Header button style with scale hover animation -->
        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource IconButtonBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource IconButtonForegroundBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="4,0,0,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter ExampletalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="{DynamicResource SurfaceHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="{DynamicResource IconButtonPressedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)"
                                             To="1.12" Duration="0:0:0.15">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)"
                                             To="1.12" Duration="0:0:0.15">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)"
                                             To="1.0" Duration="0:0:0.15">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)"
                                             To="1.0" Duration="0:0:0.15">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Main layout -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44" />   <!-- Row 0: Title bar -->
                <RowDefinition Height="Auto" /> <!-- Row 1: Search + filters -->
                <RowDefinition Height="*" />    <!-- Row 2: PR list -->
                <RowDefinition Height="Auto" /> <!-- Row 3: Status bar -->
            </Grid.RowDefinitions>

            <!-- ═══════════════════════════════════════════════════════════════
                 Row 0: Title Bar (44px fixed)
                 [Logo gradient square] PRDock  repo-path  |  "N open" badge  ●dot  [⚙]
                 ═══════════════════════════════════════════════════════════════ -->
            <Border Grid.Row="0"
                    Background="{DynamicResource TitleBarBgBrush}"
                    BorderBrush="{DynamicResource SeparatorBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="18,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Left: Logo + title + repo path -->
                    <StackPanel Grid.Column="0" Orientation="Exampletal" VerticalAlignment="Center">
                        <!-- Logo: gradient square with "P" -->
                        <Border Width="22" Height="22" CornerRadius="5" Margin="0,0,10,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="{DynamicResource LogoGradientStartColor}" Offset="0" />
                                    <GradientStop Color="{DynamicResource LogoGradientEndColor}" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="P" FontSize="11" FontWeight="ExtraBold"
                                       Foreground="{DynamicResource AvatarTextBrush}"
                                       ExampletalAlignment="Center" VerticalAlignment="Center" />
                        </Border>

                        <TextBlock Text="PRDock" FontSize="14" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,10,0" />

                        <!-- Repo summary (monospace, subtle) -->
                        <TextBlock Text="{Binding RepoSummaryText}"
                                   FontSize="11"
                                   FontFamily="{DynamicResource CodeFontFamily}"
                                   Foreground="{DynamicResource TextGhostBrush}"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                   MaxWidth="160" />

                        <!-- Section toggle: PRs / Work Items -->
                        <Border Background="{DynamicResource SurfaceRaisedBrush}"
                                CornerRadius="5" Padding="2" Margin="10,0,0,0"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Exampletal">
                                <RadioButton GroupName="Section"
                                             IsChecked="{Binding ActiveSection, Converter={StaticResource StringEqualityConverter}, ConverterParameter=PullRequests}"
                                             Command="{Binding SwitchSectionCommand}" CommandParameter="PullRequests"
                                             Style="{StaticResource FilterChipStyle}" Margin="0">
                                    <TextBlock Text="PRs" FontSize="10.5" />
                                </RadioButton>
                                <RadioButton GroupName="Section"
                                             IsChecked="{Binding ActiveSection, Converter={StaticResource StringEqualityConverter}, ConverterParameter=WorkItems}"
                                             Command="{Binding SwitchSectionCommand}" CommandParameter="WorkItems"
                                             Style="{StaticResource FilterChipStyle}" Margin="0">
                                    <TextBlock Text="Work Items" FontSize="10.5" />
                                </RadioButton>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Right: "N open" badge + status dot + loading spinner + settings -->
                    <StackPanel Grid.Column="1" Orientation="Exampletal" VerticalAlignment="Center">
                        <!-- "N open" badge -->
                        <Border Background="{DynamicResource SurfaceRaisedBrush}"
                                CornerRadius="4" Padding="8,3" Margin="0,0,10,0"
                                VerticalAlignment="Center">
                            <TextBlock FontFamily="{DynamicResource CodeFontFamily}"
                                       FontSize="11" Foreground="{DynamicResource TextMutedBrush}"
                                       VerticalAlignment="Center">
                                <Run Text="{Binding TotalCount, Mode=OneWay}" />
                                <Run Text=" open" />
                            </TextBlock>
                        </Border>

                        <!-- Status dot: RED when FailingCount > 0, GREEN when 0, with glow + pulse -->
                        <Grid Width="8" Height="8" Margin="0,0,10,0">
                            <!-- Glow layer with pulse animation (CSS: dp 1.5s ease-in-out infinite) -->
                            <Ellipse x:Name="StatusGlow" Width="8" Height="8">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{DynamicResource StatusRedBrush}" />
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <BlurEffect Radius="6" />
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Opacity" Value="0.6" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding FailingCount}" Value="0">
                                                <Setter Property="Fill" Value="{DynamicResource StatusGreenBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                <DoubleAnimation
                                                    Storyboard.TargetProperty="Opacity"
                                                    From="0.3" To="0.8"
                                                    Duration="0:0:1.5">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseInOut" />
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                            <!-- Solid dot -->
                            <Ellipse Width="7" Height="7" ExampletalAlignment="Center" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{DynamicResource StatusRedBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding FailingCount}" Value="0">
                                                <Setter Property="Fill" Value="{DynamicResource StatusGreenBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                        </Grid>

                        <!-- Loading spinner (visible when polling) -->
                        <Border Width="16" Height="16" Margin="0,0,6,0"
                                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                            <Ellipse Width="14" Height="14"
                                     StrokeThickness="2"
                                     Stroke="{DynamicResource AccentBrush}"
                                     StrokeDashArray="3,3"
                                     RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <RotateTransform x:Name="SpinnerRotation" />
                                </Ellipse.RenderTransform>
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation
                                                    Storyboard.TargetName="SpinnerRotation"
                                                    Storyboard.TargetProperty="Angle"
                                                    From="0" To="360" Duration="0:0:1" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                        </Border>

                        <!-- Refresh -->
                        <Button Command="{Binding PollNowCommand}"
                                Style="{StaticResource HeaderButtonStyle}"
                                ToolTip="Refresh (poll now)">
                            <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       Foreground="{DynamicResource IconButtonForegroundBrush}" />
                        </Button>

                        <!-- Minimize to badge -->
                        <Button Command="{Binding MinimizeToBadgeCommand}"
                                Style="{StaticResource HeaderButtonStyle}"
                                ToolTip="Minimize to badge">
                            <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       Foreground="{DynamicResource IconButtonForegroundBrush}" />
                        </Button>

                        <!-- Settings gear -->
                        <Button Command="{Binding OpenSettingsCommand}"
                                Style="{StaticResource HeaderButtonStyle}"
                                ToolTip="Settings">
                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       Foreground="{DynamicResource IconButtonForegroundBrush}" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════════
                 Row 1: Search + Filters (PR section)
                 [⌕] Search PRs... (Ctrl+K)
                 [All 9] [My PRs 5] [Failing 3] [Ready 3] [Reviewing]
                 ═══════════════════════════════════════════════════════════════ -->
            <StackPanel Grid.Row="1"
                        Background="{DynamicResource CardBackgroundBrush}">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ActiveSection}" Value="WorkItems">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <Border Padding="18,12,18,10"
                        BorderBrush="{DynamicResource SeparatorBrush}"
                        BorderThickness="0,0,0,1">
                    <StackPanel>
                        <!-- Search input -->
                        <Grid Margin="0,0,0,10">
                            <!-- Search icon (overlay) -->
                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                       Foreground="{DynamicResource TextGhostBrush}"
                                       VerticalAlignment="Center"
                                       Margin="10,0,0,0" IsHitTestVisible="False"
                                       Panel.ZIndex="1" />
                            <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="32,8,12,8"
                                     FontSize="12.5"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     CaretBrush="{DynamicResource TextPrimaryBrush}">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="TextBox">
                                                    <Border Background="{DynamicResource InputBgBrush}"
                                                            BorderBrush="{DynamicResource InputBorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="6">
                                                        <Grid>
                                                            <ScrollViewer x:Name="PART_ContentHost" Margin="0" />
                                                            <!-- Placeholder text -->
                                                            <TextBlock x:Name="Placeholder"
                                                                       Text="Search PRs... (Ctrl+K)"
                                                                       Foreground="{DynamicResource TextGhostBrush}"
                                                                       FontSize="12.5"
                                                                       VerticalAlignment="Center"
                                                                       Margin="32,0,0,0"
                                                                       IsHitTestVisible="False"
                                                                       Visibility="Collapsed" />
                                                        </Grid>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="Text" Value="">
                                                            <Setter TargetName="Placeholder" Property="Visibility" Value="Visible" />
                                                        </Trigger>
                                                        <Trigger Property="Text" Value="{x:Null}">
                                                            <Setter TargetName="Placeholder" Property="Visibility" Value="Visible" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Grid>

                        <!-- Filter chips -->
                        <StackPanel Orientation="Exampletal">
                            <!-- All -->
                            <RadioButton Style="{StaticResource FilterChipStyle}"
                                         GroupName="Filters"
                                         IsChecked="{Binding ActiveFilter, Converter={StaticResource StringEqualityConverter}, ConverterParameter=All}"
                                         Command="{Binding SetFilterCommand}" CommandParameter="All">
                                <StackPanel Orientation="Exampletal">
                                    <TextBlock Text="All" FontSize="11.5" />
                                    <Border Background="{DynamicResource SurfaceRaisedBrush}"
                                            CornerRadius="3" Padding="5,1" Margin="5,0,0,0">
                                        <TextBlock Text="{Binding TotalCount}"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   FontFamily="{DynamicResource CodeFontFamily}"
                                                   Foreground="{DynamicResource TextGhostBrush}" />
                                    </Border>
                                </StackPanel>
                            </RadioButton>

                            <!-- My PRs -->
                            <RadioButton Style="{StaticResource FilterChipStyle}"
                                         GroupName="Filters"
                                         IsChecked="{Binding ActiveFilter, Converter={StaticResource StringEqualityConverter}, ConverterParameter=My PRs}"
                                         Command="{Binding SetFilterCommand}" CommandParameter="My PRs">
                                <StackPanel Orientation="Exampletal">
                                    <TextBlock Text="My PRs" FontSize="11.5" />
                                    <Border Background="{DynamicResource SurfaceRaisedBrush}"
                                            CornerRadius="3" Padding="5,1" Margin="5,0,0,0">
                                        <TextBlock Text="{Binding MyPRsCount}"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   FontFamily="{DynamicResource CodeFontFamily}"
                                                   Foreground="{DynamicResource TextGhostBrush}" />
                                    </Border>
                                </StackPanel>
                            </RadioButton>

                            <!-- Failing -->
                            <RadioButton Style="{StaticResource FilterChipStyle}"
                                         GroupName="Filters"
                                         IsChecked="{Binding ActiveFilter, Converter={StaticResource StringEqualityConverter}, ConverterParameter=Failing}"
                                         Command="{Binding SetFilterCommand}" CommandParameter="Failing">
                                <StackPanel Orientation="Exampletal">
                                    <TextBlock Text="Failing" FontSize="11.5" />
                                    <Border Background="{DynamicResource SurfaceRaisedBrush}"
                                            CornerRadius="3" Padding="5,1" Margin="5,0,0,0">
                                        <TextBlock Text="{Binding FailingCount}"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   FontFamily="{DynamicResource CodeFontFamily}"
                                                   Foreground="{DynamicResource TextGhostBrush}" />
                                    </Border>
                                </StackPanel>
                            </RadioButton>

                            <!-- Ready -->
                            <RadioButton Style="{StaticResource FilterChipStyle}"
                                         GroupName="Filters"
                                         IsChecked="{Binding ActiveFilter, Converter={StaticResource StringEqualityConverter}, ConverterParameter=Ready}"
                                         Command="{Binding SetFilterCommand}" CommandParameter="Ready">
                                <StackPanel Orientation="Exampletal">
                                    <TextBlock Text="Ready" FontSize="11.5" />
                                    <Border Background="{DynamicResource SurfaceRaisedBrush}"
                                            CornerRadius="3" Padding="5,1" Margin="5,0,0,0">
                                        <TextBlock Text="{Binding ReadyCount}"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   FontFamily="{DynamicResource CodeFontFamily}"
                                                   Foreground="{DynamicResource TextGhostBrush}" />
                                    </Border>
                                </StackPanel>
                            </RadioButton>

                            <!-- Reviewing -->
                            <RadioButton Style="{StaticResource FilterChipStyle}"
                                         GroupName="Filters"
                                         IsChecked="{Binding ActiveFilter, Converter={StaticResource StringEqualityConverter}, ConverterParameter=Reviewing}"
                                         Command="{Binding SetFilterCommand}" CommandParameter="Reviewing">
                                <TextBlock Text="Reviewing" FontSize="11.5" />
                            </RadioButton>

                            <!-- Closed -->
                            <RadioButton Style="{StaticResource FilterChipStyle}"
                                         GroupName="Filters"
                                         IsChecked="{Binding ActiveFilter, Converter={StaticResource StringEqualityConverter}, ConverterParameter=Closed}"
                                         Command="{Binding SetFilterCommand}" CommandParameter="Closed">
                                <StackPanel Orientation="Exampletal">
                                    <TextBlock Text="Closed" FontSize="11.5" />
                                    <Border Background="{DynamicResource SurfaceRaisedBrush}"
                                            CornerRadius="3" Padding="5,1" Margin="5,0,0,0">
                                        <TextBlock Text="{Binding ClosedCount}"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   FontFamily="{DynamicResource CodeFontFamily}"
                                                   Foreground="{DynamicResource TextGhostBrush}" />
                                    </Border>
                                </StackPanel>
                            </RadioButton>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ═══════════════════════════════════════════════════════════════
                 Row 2: PR List (flat, scrollable) — visible when ActiveSection=PullRequests
                 ═══════════════════════════════════════════════════════════════ -->
            <Grid Grid.Row="2">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ActiveSection}" Value="WorkItems">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <!-- Empty state message -->
                <StackPanel ExampletalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="0,0,0,40">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FilteredPullRequests.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="&#xE8B7;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="36"
                               ExampletalAlignment="Center"
                               Foreground="{DynamicResource TextTertiaryBrush}"
                               Margin="0,0,0,12" />
                    <TextBlock Text="No pull requests"
                               FontSize="15"
                               FontWeight="SemiBold"
                               ExampletalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Text="Configure repositories in settings"
                               FontSize="12"
                               ExampletalAlignment="Center"
                               Margin="0,4,0,0"
                               Foreground="{DynamicResource TextTertiaryBrush}" />
                </StackPanel>

                <!-- Flat PR list -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              ExampletalScrollBarVisibility="Disabled"
                              Margin="0,0,0,0">
                    <ScrollViewer.Resources>
                        <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource ThinScrollBarStyle}" />
                    </ScrollViewer.Resources>
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FilteredPullRequests.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <ItemsControl ItemsSource="{Binding FilteredPullRequests}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <views:PullRequestCard />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- ═══════════════════════════════════════════════════════════════
                 Row 1-2: Work Items Section (visible when ActiveSection=WorkItems)
                 ═══════════════════════════════════════════════════════════════ -->
            <Grid Grid.Row="1" Grid.RowSpan="2"
                  DataContext="{Binding WorkItems}">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DataContext.ActiveSection, RelativeSource={RelativeSource AncestorType=Window}}" Value="WorkItems">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Work Items toolbar: query selector + search + filters -->
                <Border Grid.Row="0" Padding="18,10"
                        Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource SeparatorBrush}"
                        BorderThickness="0,0,0,1">
                    <StackPanel>
                        <!-- Query selector row -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Query name button -->
                            <Button Grid.Column="0" Cursor="Hand"
                                    Command="{Binding ToggleQueryBrowserCommand}"
                                    ExampletalContentAlignment="Left"
                                    Padding="10,7">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{DynamicResource InputBgBrush}"
                                                BorderBrush="{DynamicResource InputBorderBrush}"
                                                BorderThickness="1" CornerRadius="6"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter ExampletalAlignment="{TemplateBinding ExampletalContentAlignment}" />
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="{Binding SelectedQueryName}"
                                           FontSize="12.5"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           TextTrimming="CharacterEllipsis" />
                            </Button>

                            <!-- Refresh -->
                            <Button Grid.Column="1" Margin="6,0,0,0"
                                    Width="32" Height="32"
                                    Command="{Binding RefreshCommand}"
                                    ToolTip="Refresh"
                                    Background="{DynamicResource IconButtonBackgroundBrush}"
                                    BorderThickness="0" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                            <ContentPresenter ExampletalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource IconButtonForegroundBrush}" />
                            </Button>

                            <!-- New work item -->
                            <Button Grid.Column="2" Margin="4,0,0,0"
                                    Width="32" Height="32"
                                    Click="NewWorkItem_Click"
                                    ToolTip="New work item"
                                    Background="{DynamicResource IconButtonBackgroundBrush}"
                                    BorderThickness="0" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                            <ContentPresenter ExampletalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="{DynamicResource IconButtonForegroundBrush}" />
                            </Button>
                        </Grid>

                        <!-- Filter row: state + assignedTo -->
                        <StackPanel Orientation="Exampletal">
                            <ComboBox ItemsSource="{Binding AvailableStates}"
                                      SelectedItem="{Binding FilterState}"
                                      FontSize="11" Padding="8,4" MinWidth="80"
                                      Margin="0,0,6,0" />
                            <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="11.5" Padding="8,5" MinWidth="140">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="TextBox">
                                                    <Border Background="{DynamicResource InputBgBrush}"
                                                            BorderBrush="{DynamicResource InputBorderBrush}"
                                                            BorderThickness="1" CornerRadius="6">
                                                        <Grid>
                                                            <ScrollViewer x:Name="PART_ContentHost" Margin="0" />
                                                            <TextBlock x:Name="Placeholder"
                                                                       Text="Search work items..."
                                                                       Foreground="{DynamicResource TextGhostBrush}"
                                                                       FontSize="11.5"
                                                                       VerticalAlignment="Center" Margin="8,0,0,0"
                                                                       IsHitTestVisible="False" Visibility="Collapsed" />
                                                        </Grid>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="Text" Value="">
                                                            <Setter TargetName="Placeholder" Property="Visibility" Value="Visible" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Work items list -->
                <Grid Grid.Row="1">
                    <!-- Empty state -->
                    <StackPanel ExampletalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,40">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FilteredWorkItems.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="36"
                                   ExampletalAlignment="Center"
                                   Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,0,12" />
                        <TextBlock Text="No work items" FontSize="15" FontWeight="SemiBold"
                                   ExampletalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <TextBlock Text="Select a query to view work items"
                                   FontSize="12" ExampletalAlignment="Center" Margin="0,4,0,0"
                                   Foreground="{DynamicResource TextTertiaryBrush}" />
                    </StackPanel>

                    <!-- Work item list -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" ExampletalScrollBarVisibility="Disabled">
                        <ScrollViewer.Resources>
                            <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource ThinScrollBarStyle}" />
                        </ScrollViewer.Resources>
                        <ScrollViewer.Style>
                            <Style TargetType="ScrollViewer">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FilteredWorkItems.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ScrollViewer.Style>
                        <ItemsControl ItemsSource="{Binding FilteredWorkItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <views:WorkItemCard />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                </Grid>

                <!-- Query Browser overlay (covers work items list area) -->
                <views:QueryBrowserPanel Grid.Row="1"
                                         Panel.ZIndex="10"
                                         Visibility="{Binding IsQueryBrowserOpen, Converter={StaticResource BoolToVis}}" />
            </Grid>

            <!-- ═══════════════════════════════════════════════════════════════
                 Row 3: Status Bar (~30px fixed bottom)
                 "N PRs shown  ● X failing  ● Y ready to merge  |  Updated just now"
                 ═══════════════════════════════════════════════════════════════ -->
            <Border Grid.Row="3"
                    Background="{DynamicResource StatusBarBgBrush}"
                    BorderBrush="{DynamicResource SeparatorBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="18,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Left: summary stats (PR section) -->
                    <TextBlock Grid.Column="0"
                               FontFamily="{DynamicResource CodeFontFamily}"
                               FontSize="11" Foreground="{DynamicResource TextGhostBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveSection}" Value="WorkItems">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                        <Run Text="{Binding FilteredPullRequests.Count, Mode=OneWay}" />
                        <Run Text=" PRs shown" />
                        <Run Text="  " />
                        <Run Text="&#x25CF;" Foreground="{DynamicResource StatusRedBrush}" />
                        <Run Text=" " />
                        <Run Text="{Binding FailingCount, Mode=OneWay}" />
                        <Run Text=" failing" />
                        <Run Text="  " />
                        <Run Text="&#x25CF;" Foreground="{DynamicResource StatusGreenBrush}" />
                        <Run Text=" " />
                        <Run Text="{Binding ReadyCount, Mode=OneWay}" />
                        <Run Text=" ready" />
                    </TextBlock>

                    <!-- Left: summary stats (Work Items section) -->
                    <TextBlock Grid.Column="0"
                               FontFamily="{DynamicResource CodeFontFamily}"
                               FontSize="11" Foreground="{DynamicResource TextGhostBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveSection}" Value="WorkItems">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                        <Run Text="{Binding WorkItems.FilteredWorkItems.Count, Mode=OneWay}" />
                        <Run Text=" work items" />
                    </TextBlock>

                    <!-- Right: last updated -->
                    <TextBlock Grid.Column="1"
                               FontFamily="{DynamicResource CodeFontFamily}"
                               FontSize="11" Foreground="{DynamicResource TextGhostBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{Binding StatusText}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveSection}" Value="WorkItems">
                                        <Setter Property="Text" Value="{Binding WorkItems.StatusText}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════
             Settings Flyout Overlay (overlays entire window when open)
             MUST keep x:Name="SettingsFlyoutPanel" — code-behind references it
             ═══════════════════════════════════════════════════════════════ -->
        <Border x:Name="SettingsOverlay"
                Visibility="Collapsed"
                Background="{DynamicResource OverlayBgBrush}"
                Panel.ZIndex="100"
                Opacity="0">
            <Border x:Name="SettingsFlyoutBorder"
                    ExampletalAlignment="Right"
                    Width="360"
                    Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource SubtleBorderBrush}"
                    BorderThickness="1,0,0,0">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="SettingsFlyoutTranslate" X="360" />
                </Border.RenderTransform>
                <views:SettingsFlyout x:Name="SettingsFlyoutPanel" />
            </Border>
        </Border>
    </Grid>
</Window>
