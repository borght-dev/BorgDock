<Window x:Class="PRDock.App.Views.WorktreePruneDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PRDock.App.ViewModels"
        Title="Prune Worktrees"
        Width="620" Height="460"
        MinWidth="480" MinHeight="340"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Worktrees"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,8" />

        <!-- Worktree list -->
        <ListBox Grid.Row="1"
                 AutomationProperties.AutomationId="WorktreeListBox"
                 ItemsSource="{Binding Worktrees}"
                 ExampletalContentAlignment="Stretch"
                 ScrollViewer.ExampletalScrollBarVisibility="Disabled"
                 BorderThickness="1"
                 BorderBrush="{DynamicResource BorderBrush}">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:WorktreeItemViewModel}">
                    <Grid Margin="4,4,4,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <CheckBox Grid.Column="0"
                                  AutomationProperties.AutomationId="WorktreeCheckBox"
                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                  VerticalAlignment="Top"
                                  Margin="0,2,8,0">
                            <CheckBox.Style>
                                <Style TargetType="CheckBox">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRemoved}" Value="True">
                                            <Setter Property="IsEnabled" Value="False" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </CheckBox.Style>
                        </CheckBox>

                        <StackPanel Grid.Column="1">
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}">
                                <Run Text="{Binding BranchName, Mode=OneWay}" />
                                <Run Text=" " />
                                <Run Text="{Binding RepoDisplayName, Mode=OneWay}"
                                     Foreground="{DynamicResource TextSecondaryBrush}"
                                     FontWeight="Normal" FontSize="11" />
                            </TextBlock>

                            <TextBlock Text="{Binding WorktreePath, Mode=OneWay}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="11"
                                       TextTrimming="CharacterEllipsis" />

                            <TextBlock Text="{Binding PrStatus, Mode=OneWay}"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,2,0,0" />

                            <!-- Removal status -->
                            <TextBlock Text="Removed"
                                       FontSize="11"
                                       Foreground="Green"
                                       Visibility="{Binding IsRemoved, Converter={StaticResource BoolToVis}}" />

                            <TextBlock Text="{Binding RemovalError, Mode=OneWay}"
                                       FontSize="11"
                                       Foreground="{DynamicResource StatusRedBrush}"
                                       TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RemovalError}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Loading / progress -->
        <StackPanel Grid.Row="2" Margin="0,8,0,0">
            <ProgressBar AutomationProperties.AutomationId="PruneProgressBar"
                         IsIndeterminate="{Binding IsLoading}"
                         Maximum="{Binding TotalToRemove}"
                         Value="{Binding RemovedCount}"
                         Height="4"
                         Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />

            <ProgressBar AutomationProperties.AutomationId="RemoveProgressBar"
                         Maximum="{Binding TotalToRemove}"
                         Value="{Binding RemovedCount}"
                         Height="4"
                         Visibility="{Binding IsRemoving, Converter={StaticResource BoolToVis}}" />

            <TextBlock AutomationProperties.AutomationId="StatusMessageText"
                       Text="{Binding StatusMessage}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="12"
                       Margin="0,4,0,0" />
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="3"
                    Orientation="Exampletal"
                    ExampletalAlignment="Right"
                    Margin="0,12,0,0">
            <Button AutomationProperties.AutomationId="SelectAllButton"
                    Content="Select All"
                    Command="{Binding SelectAllCommand}"
                    Padding="12,6"
                    Margin="0,0,4,0" />
            <Button AutomationProperties.AutomationId="SelectNoneButton"
                    Content="Select None"
                    Command="{Binding SelectNoneCommand}"
                    Padding="12,6"
                    Margin="0,0,12,0" />
            <Button AutomationProperties.AutomationId="RemoveSelectedButton"
                    Content="Remove Selected"
                    Command="{Binding RemoveSelectedCommand}"
                    Padding="12,6"
                    Margin="0,0,4,0" />
            <Button AutomationProperties.AutomationId="CloseButton"
                    Content="Close"
                    IsCancel="True"
                    Padding="12,6"
                    Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</Window>
