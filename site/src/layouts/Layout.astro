---
import '~/styles/tokens.css';
import '~/styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "BorgDock is a docked developer cockpit. PRs, CI, Claude Code, worktrees, ADO work items, SQL, file search — every tab you'd otherwise have open, one keybinding away.",
} = Astro.props;
---

<!doctype html>
<html class="dark" lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />

    {/* Persist theme before paint to avoid FOUC. */}
    <script is:inline>
      (function () {
        try {
          const saved = localStorage.getItem('prdock-theme');
          if (saved === 'light') document.documentElement.classList.remove('dark');
          else document.documentElement.classList.add('dark');
        } catch {}
      })();
    </script>
  </head>

  <body>
    <slot />
  </body>
</html>
