---
import '~/styles/tokens.css';
import '~/styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "BorgDock is a docked developer cockpit. PRs, CI, Claude Code, worktrees, ADO work items, SQL, file search — every tab you'd otherwise have open, one keybinding away.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />

    {/* Apply theme before paint. System preference by default; explicit
        localStorage value ('light' | 'dark') overrides. Track system changes
        only when no explicit override is set. */}
    <script is:inline>
      (function () {
        try {
          var mql = window.matchMedia('(prefers-color-scheme: dark)');
          var apply = function () {
            var saved = localStorage.getItem('prdock-theme');
            var isDark = saved === 'dark' || (saved !== 'light' && mql.matches);
            document.documentElement.classList.toggle('dark', isDark);
          };
          apply();
          if (mql.addEventListener) {
            mql.addEventListener('change', function () {
              var s = localStorage.getItem('prdock-theme');
              if (s !== 'light' && s !== 'dark') apply();
            });
          }
        } catch (e) {}
      })();
    </script>

    {/* Detect platform and rewrite the hero download CTA before paint.
        Defaults (in markup) target macOS; overridden client-side for
        Windows/Linux. Sizes mirror the cards on /download. */}
    <script is:inline>
      (function () {
        function apply() {
          try {
            var ua = navigator.userAgent || '';
            var uaPlat = (navigator.userAgentData && navigator.userAgentData.platform) || '';
            var plat = (uaPlat || navigator.platform || '').toLowerCase();
            var os = 'mac';
            if (/win/.test(plat) || /windows/i.test(ua)) os = 'win';
            else if (/linux/.test(plat) || /linux/i.test(ua)) os = 'linux';
            if (os === 'mac') return;
            var labels = { win: 'Download for Windows', linux: 'Download for Linux' };
            var sizes = { win: '42 MB', linux: '46 MB' };
            var others = { win: 'macOS · Linux', linux: 'macOS · Windows' };
            var label = document.querySelector('[data-download-label]');
            var size = document.querySelector('[data-download-size]');
            var other = document.querySelector('[data-download-other]');
            if (label) label.textContent = labels[os];
            if (size) size.textContent = sizes[os];
            if (other) other.textContent = others[os];
          } catch (e) {}
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', apply);
        } else {
          apply();
        }
      })();
    </script>
  </head>

  <body>
    <slot />
  </body>
</html>
