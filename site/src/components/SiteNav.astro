---
import { BorgDockLogo } from '~/components/ui/BorgDockLogo';
import ThemeToggle from '~/components/ThemeToggle';

type NavKey = 'home' | 'features' | 'gallery' | 'changelog' | 'download';

interface Props {
  current?: NavKey;
}

const { current = 'home' } = Astro.props;

interface Link {
  key: NavKey | 'github';
  label: string;
  href: string;
  external?: boolean;
}

const links: Link[] = [
  { key: 'features', label: 'Features', href: '/features' },
  { key: 'gallery', label: 'Gallery', href: '/gallery' },
  { key: 'changelog', label: 'Changelog', href: '/changelog' },
  { key: 'github', label: 'GitHub', href: 'https://github.com/borght-dev/borgdock', external: true },
  { key: 'download', label: 'Download', href: '/download' },
];
---

<nav class="site-nav">
  <div class="site-nav__inner">
    <a href="/" class="site-nav__brand" aria-label="BorgDock — home">
      <BorgDockLogo size={22} />
      <span class="site-nav__brand-name">BorgDock</span>
    </a>
    <span class="site-nav__version">v0.14.0</span>

    <span class="site-nav__spacer"></span>

    {/* Mobile toggle — pure CSS disclosure, no JS. */}
    <input
      type="checkbox"
      id="site-nav-toggle"
      class="site-nav__toggle"
      aria-label="Menu"
    />

    <div class="site-nav__links">
      {
        links.map((l) => (
          <a
            href={l.href}
            class="site-nav__link"
            target={l.external ? '_blank' : undefined}
            rel={l.external ? 'noopener noreferrer' : undefined}
            aria-current={current === l.key ? 'page' : undefined}
          >
            {l.label}
            {l.external && (
              <svg
                width="10"
                height="10"
                viewBox="0 0 16 16"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                style="opacity: 0.55;"
                aria-hidden="true"
              >
                <path d="M6 3h7v7M13 3L6 10" />
              </svg>
            )}
          </a>
        ))
      }
      <ThemeToggle client:load />
      <a href="/download" class="site-nav__cta">Download</a>
    </div>
  </div>
</nav>
